---
/**
 * SectionIndex — local navigation for long detail pages.
 *
 * Renders a numbered, reference-catalog-style list of sections as:
 *   · a sticky side rail on wide viewports (≥ 1080px)
 *   · a compact <details> jump menu at the top of the body on narrow viewports
 *
 * Static-first: works fully without JavaScript. A small optional script
 * progressively highlights the currently visible section using
 * IntersectionObserver — no framework, no hydration.
 *
 * Design direction: "bulletin-like labels, rails, stamps, or reference cues"
 * — the rail feels like a field-manual tab column, not app navigation.
 */

export interface SectionItem {
  /** "01", "02", …; shown as a mono code on the left. */
  step: string;
  /** Title shown next to the step. */
  label: string;
  /** The id of the <section> / <header> to jump to. Do not include the '#'. */
  id: string;
}

export interface Props {
  items: readonly SectionItem[];
  /** Small eyebrow shown above the list. */
  eyebrow?: string;
}

const { items, eyebrow = "In this entry" } = Astro.props;
---
<nav class="nsb-section-index" aria-label="Sections in this entry">
  {/* Mobile / narrow: collapsible jump menu */}
  <details class="nsb-section-index__mobile" open={false}>
    <summary class="nsb-section-index__summary">
      <span>{eyebrow}</span>
      <span class="nsb-section-index__summary-count">{items.length} sections</span>
    </summary>
    <ol class="nsb-section-index__list">
      {items.map((i) => (
        <li class="nsb-section-index__item">
          <a class="nsb-section-index__link" href={`#${i.id}`} data-target={i.id}>
            <span class="nsb-section-index__step">{i.step}</span>
            <span class="nsb-section-index__label">{i.label}</span>
          </a>
        </li>
      ))}
    </ol>
  </details>

  {/* Desktop / wide: sticky rail */}
  <aside class="nsb-section-index__rail" aria-hidden="false">
    <p class="nsb-section-index__rail-head">{eyebrow}</p>
    <ol class="nsb-section-index__list nsb-section-index__list--rail">
      {items.map((i) => (
        <li class="nsb-section-index__item">
          <a class="nsb-section-index__link" href={`#${i.id}`} data-target={i.id}>
            <span class="nsb-section-index__step">{i.step}</span>
            <span class="nsb-section-index__label">{i.label}</span>
          </a>
        </li>
      ))}
    </ol>
  </aside>
</nav>

{/* Progressive enhancement: highlight the active section while the
    reader scrolls. Harmless if disabled — nothing about the static
    render depends on this.

    Implementation note: Astro compiles <script> tags to ES modules by
    default. Inside an ES module, `document.currentScript` is null, so
    the original version of this enhancement (which used
    `currentScript?.previousElementSibling` to find the <nav>) silently
    no-opped in production. We switched to a plain
    `querySelectorAll('.nsb-section-index')` lookup + iterate so the
    script finds every index on the page regardless of how Astro
    wraps it. */}
<script>
  const navs = document.querySelectorAll<HTMLElement>(".nsb-section-index");
  for (const nav of navs) {
    const links = Array.from(
      nav.querySelectorAll<HTMLAnchorElement>("a[data-target]"),
    );
    if (links.length === 0) continue;

    // Group links by their target section id. Each section may have two
    // anchors pointing at it (one in the mobile <details> menu, one in
    // the desktop rail) — both should light up together.
    const byId = new Map<string, HTMLAnchorElement[]>();
    for (const a of links) {
      const id = a.dataset.target!;
      const list = byId.get(id) ?? [];
      list.push(a);
      byId.set(id, list);
    }

    const sections = Array.from(byId.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);
    if (sections.length === 0) continue;

    let activeId: string | null = null;
    const setActive = (id: string | null) => {
      if (id === activeId) return;
      activeId = id;
      for (const [key, anchors] of byId) {
        const on = key === id;
        for (const a of anchors) {
          a.classList.toggle("is-active", on);
          if (on) a.setAttribute("aria-current", "location");
          else a.removeAttribute("aria-current");
        }
      }
    };

    // rootMargin shrinks the viewport's "counts as intersecting" band to
    // a horizontal strip spanning ~30–40% of the screen height. The
    // currently-visible section is the topmost one whose header falls
    // inside that band, which matches what a reader's eye is actually
    // tracking at any given scroll offset.
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) setActive(visible[0]!.target.id);
      },
      { rootMargin: "-30% 0px -60% 0px", threshold: [0, 1] },
    );
    for (const s of sections) io.observe(s);

    // Seed the active state: whichever section's top is closest to the
    // viewport's sweet-spot on first paint wins. Without this seed the
    // rail stays blank until the reader moves, which reads as "nothing
    // is selected" instead of "this is where you are".
    const seed = () => {
      const pivot = window.innerHeight * 0.35;
      let best: { id: string; dist: number } | null = null;
      for (const s of sections) {
        const top = s.getBoundingClientRect().top;
        const dist = Math.abs(top - pivot);
        if (best === null || dist < best.dist) best = { id: s.id, dist };
      }
      if (best) setActive(best.id);
    };
    seed();
  }
</script>

<style>
  .nsb-section-index { display: contents; }

  /* --- Mobile collapsible jump menu --------------------------------- */
  .nsb-section-index__mobile {
    display: block;
    margin-bottom: var(--space-6);
    border: 3px solid var(--color-frame);
    background: var(--color-surface);
  }
  .nsb-section-index__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    list-style: none;
    cursor: pointer;
    padding: var(--space-3) var(--space-5);
    background: var(--color-frame);
    color: var(--color-surface);
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
  }
  .nsb-section-index__summary > .nsb-eyebrow {
    color: var(--color-yellow);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    margin: 0;
  }
  .nsb-section-index__summary::-webkit-details-marker { display: none; }
  .nsb-section-index__summary::after {
    content: "▾";
    margin-left: auto;
    color: var(--color-yellow);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    transition: transform var(--dur-fast) var(--ease);
  }
  .nsb-section-index__mobile[open] .nsb-section-index__summary::after {
    transform: rotate(180deg);
  }
  .nsb-section-index__summary-count {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-surface);
    opacity: 0.7;
  }

  /* --- Desktop sticky rail: a framed side panel -------------------- */
  .nsb-section-index__rail { display: none; }

  @media (min-width: 1080px) {
    .nsb-section-index__mobile { display: none; }
    .nsb-section-index__rail {
      display: block;
      position: sticky;
      top: var(--space-6);
      max-height: calc(100vh - var(--space-8));
      overflow: auto;
      background: var(--color-surface);
      border: 3px solid var(--color-frame);
    }
    .nsb-section-index__rail-head {
      margin: 0;
      padding: var(--space-3) var(--space-4);
      background: var(--color-frame);
      color: var(--color-yellow);
      font-family: var(--font-sans);
      font-weight: 900;
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      font-size: var(--text-xs);
    }
  }

  /* --- Shared list styles ------------------------------------------- */
  .nsb-section-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .nsb-section-index__item {
    border-bottom: 2px solid var(--color-frame);
  }
  .nsb-section-index__item:last-child { border-bottom: 0; }

  .nsb-section-index__link {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-3);
    align-items: center;
    padding: 0;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    transition: background var(--dur-fast) var(--ease),
                color var(--dur-fast) var(--ease);
  }
  .nsb-section-index__link:hover { background: var(--color-paper-alt); }
  .nsb-section-index__link:hover .nsb-section-index__step { background: var(--accent-current); }

  /* Step number as a filled black badge (matches SectionHeader step). */
  .nsb-section-index__step {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 900;
    font-feature-settings: "tnum";
    color: var(--color-surface);
    background: var(--color-frame);
    padding: var(--space-3) 0;
    text-align: center;
    line-height: 1;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 2px solid var(--color-frame);
  }
  .nsb-section-index__label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.2;
    letter-spacing: -0.01em;
    padding: var(--space-3) var(--space-4) var(--space-3) 0;
  }

  /* Active state — yellow row, black step, black label. */
  .nsb-section-index__link.is-active { background: var(--color-yellow); }
  .nsb-section-index__link.is-active .nsb-section-index__step {
    background: var(--color-frame);
    color: var(--color-yellow);
  }
  .nsb-section-index__link.is-active .nsb-section-index__label {
    color: var(--color-yellow-ink);
    font-weight: 900;
  }
</style>
