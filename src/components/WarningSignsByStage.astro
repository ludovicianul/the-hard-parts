---
/**
 * WarningSignsByStage — FM-specific renderer for the canonical
 * `warningSigns: { early, mid, late }` block.
 *
 * Presented as three labeled stacks, visually analogous to field-guide
 * progression panels:
 *
 *   EARLY        MID          LATE
 *   ------       ------       ------
 *   - ...        - ...        - ...
 *
 * Keeps the structural meaning (progression, escalation) intact per docs'
 * rendering rules — do not flatten structured data into a single list.
 */

import type { FailureModeEntry } from "@/content/schemas/failure-mode";

export interface Props {
  warningSigns: FailureModeEntry["warningSigns"];
}

const { warningSigns } = Astro.props;

const stages = [
  { code: "EARLY", label: "Early", items: warningSigns.early },
  { code: "MID", label: "Mid", items: warningSigns.mid },
  { code: "LATE", label: "Late", items: warningSigns.late },
] as const;
---
<div class="nsb-warning-stages" aria-label="Warning signs by stage">
  {stages.map((s, i) => (
    <div class={`nsb-warning-stages__col nsb-warning-stages__col--${s.code.toLowerCase()}`}>
      <div class="nsb-warning-stages__head">
        <p class="nsb-warning-stages__code nsb-eyebrow">{s.code}</p>
        <span class="nsb-warning-stages__intensity" aria-hidden="true">
          {Array.from({ length: 3 }).map((_, j) => (
            <span class={`nsb-warning-stages__bar${j <= i ? " is-on" : ""}`} />
          ))}
        </span>
      </div>
      <h4 class="nsb-warning-stages__label">{s.label}</h4>
      <ul class="nsb-warning-stages__list">
        {s.items.map((item) => (
          <li class="nsb-warning-stages__item">{item}</li>
        ))}
      </ul>
    </div>
  ))}
</div>

<style>
  /* Three framed columns with tabloid-saturated HEADER STRIPS:
     EARLY = yellow, MID = amber (FM accent tint), LATE = red. The column
     bodies stay white so the prose is readable; the strip carries the
     color-as-information signal. */
  .nsb-warning-stages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 3px solid var(--color-frame);
    margin-block: var(--space-5);
    background: var(--color-surface);
  }
  .nsb-warning-stages__col {
    border-right: 3px solid var(--color-frame);
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .nsb-warning-stages__col:last-child { border-right: 0; }

  /* Header strip — saturated color per stage. */
  .nsb-warning-stages__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 3px solid var(--color-frame);
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .nsb-warning-stages__col--early .nsb-warning-stages__head {
    background: var(--color-yellow);
    color: var(--color-yellow-ink);
  }
  .nsb-warning-stages__col--mid .nsb-warning-stages__head {
    background: var(--accent-fm);
    color: var(--color-surface);
  }
  .nsb-warning-stages__col--late .nsb-warning-stages__head {
    background: var(--color-red);
    color: var(--color-surface);
  }
  .nsb-warning-stages__code { margin: 0; font-size: var(--text-sm); color: inherit; }

  .nsb-warning-stages__intensity { display: inline-flex; gap: 3px; }
  .nsb-warning-stages__bar {
    width: 14px;
    height: 5px;
    background: currentColor;
    opacity: 0.28;
    display: inline-block;
  }
  .nsb-warning-stages__bar.is-on { opacity: 1; }

  .nsb-warning-stages__label {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 900;
    margin: 0 0 var(--space-4) 0;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--color-ink);
    padding: var(--space-5) var(--space-5) 0;
  }
  .nsb-warning-stages__list {
    list-style: none;
    padding: 0 var(--space-5) var(--space-5);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .nsb-warning-stages__item {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-ink);
    padding-left: 1.25rem;
    position: relative;
  }
  /* Square bullet — each stage tints the bullet to its own header color so
     the stage identity carries through into the list body. */
  .nsb-warning-stages__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 7px;
    height: 7px;
    background: var(--color-frame);
  }
  .nsb-warning-stages__col--early .nsb-warning-stages__item::before { background: var(--color-yellow-ink); }
  .nsb-warning-stages__col--mid   .nsb-warning-stages__item::before { background: var(--accent-fm); }
  .nsb-warning-stages__col--late  .nsb-warning-stages__item::before { background: var(--color-red); }

  @media (max-width: 820px) {
    .nsb-warning-stages { grid-template-columns: 1fr; }
    .nsb-warning-stages__col {
      border-right: 0;
      border-bottom: 3px solid var(--color-frame);
    }
    .nsb-warning-stages__col:last-child { border-bottom: 0; }
  }
</style>
