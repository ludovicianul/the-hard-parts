---
/**
 * WarningSignsByStage — FM-specific renderer for the canonical
 * `warningSigns: { early, mid, late }` block.
 *
 * Presented as three labeled stacks, visually analogous to field-guide
 * progression panels:
 *
 *   EARLY        MID          LATE
 *   ------       ------       ------
 *   - ...        - ...        - ...
 *
 * Keeps the structural meaning (progression, escalation) intact per docs'
 * rendering rules — do not flatten structured data into a single list.
 */

import type { FailureModeEntry } from "@/content/schemas/failure-mode";

export interface Props {
  warningSigns: FailureModeEntry["warningSigns"];
}

const { warningSigns } = Astro.props;

const stages = [
  { code: "EARLY", label: "Early", items: warningSigns.early },
  { code: "MID", label: "Mid", items: warningSigns.mid },
  { code: "LATE", label: "Late", items: warningSigns.late },
] as const;
---
<div class="nsb-warning-stages" aria-label="Warning signs by stage">
  {stages.map((s, i) => (
    <div class={`nsb-warning-stages__col nsb-warning-stages__col--${s.code.toLowerCase()}`}>
      <div class="nsb-warning-stages__head">
        <p class="nsb-warning-stages__code nsb-eyebrow">{s.code}</p>
        <span class="nsb-warning-stages__intensity" aria-hidden="true">
          {Array.from({ length: 3 }).map((_, j) => (
            <span class={`nsb-warning-stages__bar${j <= i ? " is-on" : ""}`} />
          ))}
        </span>
      </div>
      <h4 class="nsb-warning-stages__label">{s.label}</h4>
      <ul class="nsb-warning-stages__list">
        {s.items.map((item) => (
          <li class="nsb-warning-stages__item">{item}</li>
        ))}
      </ul>
    </div>
  ))}
</div>

<style>
  .nsb-warning-stages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 2px solid var(--accent-current);
    border-left: var(--rule);
    margin-block: var(--space-5);
  }
  .nsb-warning-stages__col {
    padding: var(--space-5);
    border-right: var(--rule);
    border-bottom: var(--rule);
    background: var(--color-surface);
    position: relative;
  }
  /* Color-as-information: stage severity builds across the three columns.
     EARLY = neutral surface, MID = soft amber wash, LATE = stronger amber tint.
     Readers absorb "things are getting worse" visually before reading. */
  .nsb-warning-stages__col--early { background: var(--color-surface); }
  .nsb-warning-stages__col--mid   { background: var(--accent-current-wash); }
  .nsb-warning-stages__col--late  { background: var(--accent-current-tint); }

  .nsb-warning-stages__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .nsb-warning-stages__code {
    margin: 0;
    color: var(--accent-current-deep, var(--accent-current));
    font-weight: 600;
  }
  /* Tiny three-bar intensity indicator — informational, not decorative. */
  .nsb-warning-stages__intensity {
    display: inline-flex;
    gap: 3px;
  }
  .nsb-warning-stages__bar {
    width: 14px;
    height: 4px;
    background: var(--color-rule);
    display: inline-block;
  }
  .nsb-warning-stages__bar.is-on {
    background: var(--accent-current);
  }

  .nsb-warning-stages__label {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 700;
    margin: 0 0 var(--space-4) 0;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .nsb-warning-stages__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .nsb-warning-stages__item {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-ink);
    padding-left: var(--space-4);
    position: relative;
  }
  .nsb-warning-stages__item::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent-current-deep, var(--accent-current));
  }
  @media (max-width: 820px) {
    .nsb-warning-stages { grid-template-columns: 1fr; }
  }
</style>
