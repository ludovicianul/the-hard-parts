---
/**
 * EntryCard — reference-record card used on landing pages and the homepage
 * preview strip. Category-agnostic by design; the caller supplies the code,
 * href, title, summary, and a small set of meta bits.
 *
 * Styling follows docs/design-direction.md:
 *   · cards read as "reference records", not product tiles
 *   · no rounded corners, no soft shadow, no gradient
 *   · code/identifier eyebrow at the top (e.g. "FM · planning")
 *   · serif title, dim summary, mono meta line
 *   · hover shifts background; accent underline on title
 */

import { CATEGORIES } from "@/lib/categories";
import type { CategoryCode } from "@/content/schemas/shared";

export interface Props {
  code: CategoryCode;
  slug: string;
  title: string;
  summary: string;
  /** Optional subcategory / layer shown next to the code in the eyebrow. */
  subcategory?: string;
  /** Short mono meta bits shown at the bottom: "severity: high", etc. */
  metaBits?: readonly string[];
  /** Override the href (default: canonical detail route for the entry). */
  href?: string;
  /** Visual accent for hover + title underline. Defaults to entry category. */
  accent?: "fm" | "td" | "rf" | "ep";
  /** Severity (FM-specific). Drives the bottom tick-bar intensity. */
  severity?: "low" | "medium" | "medium-high" | "high" | "critical";
  /** Optional decorative catalog reference number, e.g. "007". */
  refNum?: string;
  /** Fill variant for the card. Drives color-as-information in the catalog. */
  variant?: "default" | "yellow" | "blue" | "red" | "paper";
  /**
   * If true, ignore `variant` and fill the card background using the severity
   * color ramp (see --sev-* tokens). The ramp is an achromatic grayscale
   * (paper → near-black) so it can never collide with the category color
   * palette (FM = green, TD = orange, RF = crimson, EP = purple) or the
   * hero signal colors (yellow, blue). Used on the FM landing and the
   * homepage preview strip so a reader can read weight before names.
   */
  fillFromSeverity?: boolean;
}

const {
  code,
  slug,
  title,
  summary,
  subcategory,
  metaBits = [],
  href,
  accent,
  severity,
  refNum,
  variant = "default",
  fillFromSeverity = false,
} = Astro.props;

const desc = CATEGORIES[code];
const resolvedHref = href ?? `/${desc.route}/${slug}`;
const resolvedAccent = accent ?? (code.toLowerCase() as "fm" | "td" | "rf" | "ep");

// Severity → number of filled tick bars (out of 5).
const severitySteps: Record<NonNullable<Props["severity"]>, number> = {
  low: 1,
  medium: 2,
  "medium-high": 3,
  high: 4,
  critical: 5,
};
const sevStep = severity ? severitySteps[severity] : 0;
---
<a
  class:list={[
    "nsb-entry-card",
    // When the caller asks the card to fill from severity, we ignore the
    // variant prop entirely and key off the severity level instead. This
    // keeps the color-as-information contract tight: on the FM catalog,
    // card color means severity, nothing else.
    fillFromSeverity && severity
      ? `nsb-entry-card--fill-${severity.replace(/\s+/g, "-")}`
      : `nsb-entry-card--v-${variant}`,
    severity && `nsb-entry-card--sev-${severity.replace(/\s+/g, "-")}`,
  ]}
  href={resolvedHref}
  data-accent={resolvedAccent}
>
  <div class="nsb-entry-card__body">
    <div class="nsb-entry-card__top">
      <span class="nsb-entry-card__code">
        {desc.shortLabel}{refNum && <span class="nsb-entry-card__refnum">-{refNum}</span>}
      </span>
      {subcategory && <span class="nsb-entry-card__sub">{subcategory}</span>}
    </div>
    <h3 class="nsb-entry-card__title">{title}</h3>
    <p class="nsb-entry-card__summary">{summary}</p>
    {(metaBits.length > 0 || severity) && (
      <div class="nsb-entry-card__meta">
        {severity && (
          <span class="nsb-entry-card__meta-bars" aria-hidden="true">
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={["nsb-entry-card__meta-bar", { "is-on-full": i < sevStep }]} />
            ))}
          </span>
        )}
        {metaBits.length > 0 && (
          <span class="nsb-entry-card__meta-text">{metaBits.filter(Boolean).join("  ·  ")}</span>
        )}
      </div>
    )}
  </div>
</a>

<style>
  /* --- Base card: a framed rectangle with a heavy top-row "masthead" that
         carries the code/ref pill (black) and optional subcategory (right-aligned).
         Hover shifts the card up and drops a crisp black offset shadow for the
         tabloid "clipping from a newspaper" feel. ------------------------- */
  .nsb-entry-card {
    display: block;
    position: relative;
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
    text-decoration: none;
    color: inherit;
    min-height: 14rem;
    transition: transform var(--dur-fast) var(--ease),
                box-shadow var(--dur-fast) var(--ease),
                background var(--dur-fast) var(--ease);
  }
  .nsb-entry-card:hover,
  .nsb-entry-card:focus-visible {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 0 var(--color-frame);
    outline: none;
  }

  /* Variants — generic color fills for non-FM uses (Tech Decisions, etc.). */
  .nsb-entry-card--v-yellow  { background: var(--color-yellow-soft); color: var(--color-yellow-ink); }
  .nsb-entry-card--v-red     { background: var(--color-red);         color: var(--color-surface);    }
  .nsb-entry-card--v-blue    { background: var(--color-blue);        color: var(--color-surface);    }
  .nsb-entry-card--v-paper   { background: var(--color-paper-alt);   color: var(--color-ink);        }
  .nsb-entry-card--v-default { background: var(--color-surface);     color: var(--color-ink);        }

  /* Severity ramp — card background reads as a heat-map. All five steps
     use the shared --sev-* tokens so the legend on the FM landing, the
     cards on the grid, and the severity pill on the detail page all
     resolve to the exact same color for any given level. */
  .nsb-entry-card--fill-low         { background: var(--sev-low);         color: var(--sev-low-ink);         }
  .nsb-entry-card--fill-medium      { background: var(--sev-medium);      color: var(--sev-medium-ink);      }
  .nsb-entry-card--fill-medium-high { background: var(--sev-medium-high); color: var(--sev-medium-high-ink); }
  .nsb-entry-card--fill-high        { background: var(--sev-high);        color: var(--sev-high-ink);        }
  .nsb-entry-card--fill-critical    { background: var(--sev-critical);    color: var(--sev-critical-ink);    }

  .nsb-entry-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5) var(--space-4);
    height: 100%;
  }

  /* Top row — code pill-like marker + right-aligned subcategory eyebrow. */
  .nsb-entry-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid currentColor;
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
  }
  .nsb-entry-card__code {
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
    color: inherit;
  }
  .nsb-entry-card__refnum { font-feature-settings: "tnum"; }
  .nsb-entry-card__sub { color: inherit; opacity: 0.75; font-weight: 700; }

  .nsb-entry-card__title {
    font-family: var(--font-sans);
    font-size: clamp(var(--text-lg), 2.1vw, var(--text-xl));
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    line-height: 1;
    margin: var(--space-2) 0 0 0;
    color: inherit;
  }

  .nsb-entry-card__summary {
    font-family: var(--font-serif);
    color: inherit;
    opacity: 0.85;
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    margin: 0;
    flex: 1 1 auto;
  }

  /* Meta row — severity bars (black block tick marks) + mono meta text. */
  .nsb-entry-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-3);
    border-top: 2px solid currentColor;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: inherit;
  }
  .nsb-entry-card__meta-bars { display: inline-flex; gap: 3px; }
  .nsb-entry-card__meta-bar {
    width: 18px;
    height: 8px;
    background: currentColor;
    opacity: 0.18;
    display: inline-block;
  }
  .nsb-entry-card__meta-bar.is-on-full { opacity: 1; }
  .nsb-entry-card__meta-text { opacity: 0.85; }
</style>
