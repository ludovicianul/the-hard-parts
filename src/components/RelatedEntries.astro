---
/**
 * RelatedEntries — reference-catalog cross-reference block.
 *
 * Renders a single relationship field (e.g. `oftenLeadsTo`, `relatedRedFlags`)
 * as a unified reference list with two clearly distinguished tiers:
 *
 *   · Resolved  — real linked entries with a mono call-number prefix
 *                 (`FM · 007 · friendly-rewrite`) and a sans title.
 *
 *   · Pending   — editorial-backlog references the guide names but has not yet
 *                 authored. Shown in the same list structure, prefixed by a
 *                 `PENDING` marker in accent, in plain (non-italic) serif so
 *                 they read like legitimate catalog entries still awaiting a
 *                 page — honest, not muted.
 *
 * No pills, no chips, no paper-alt box. The whole block is framed by a thin
 * accent rule and a bulletin eyebrow so it reads as part of a reference
 * system, not a soft aside.
 */

import { partitionRefs } from "@/lib/resolve";
import { CATEGORIES } from "@/lib/categories";
import type { CategoryCode } from "@/content/schemas/shared";

export interface Props {
  /** Small mono label, e.g. "OFTEN LEADS TO" or "RELATED RED FLAGS". */
  eyebrow: string;
  /** Section title, e.g. "Often leads to". */
  title: string;
  /** Raw reference array from content. Mixed slugs / phrases allowed. */
  refs: readonly string[] | undefined;
  /**
   * If provided, constrain the linked group to this category only.
   * Resolved refs outside this code still render (they are valid links) but
   * are visually grouped under a "cross-category" subhead.
   */
  expectCategory?: CategoryCode;
  /** Smaller treatment for tight clusters of related blocks. */
  dense?: boolean;
}

const { eyebrow, title, refs, expectCategory, dense = false } = Astro.props;
const { resolved, unresolved } = partitionRefs(refs);

// Nothing to show — render nothing (rather than an empty section).
const hasAny = resolved.length + unresolved.length > 0;

// Partition resolved entries into expected-category vs cross-category for
// subtle visual grouping.
const inExpected = expectCategory
  ? resolved.filter((r) => r.code === expectCategory)
  : resolved;
const crossCategory = expectCategory
  ? resolved.filter((r) => r.code !== expectCategory)
  : [];

// NOTE: catalog numbers come from each resolved ref's own `refNum` (e.g.
// "05" for the 5th FM, "045" for the 45th TD), *not* a locally-reset
// counter. The number a reader sees next to a link matches the pill on
// that target entry's own detail masthead, so "FM-05" here IS the
// entry you land on when you click. See `resolve.ts · formatRefCode`.
---
{hasAny && (
  <section
    class:list={[
      "nsb-related",
      { "nsb-related--dense": dense },
    ]}
    aria-label={title}
  >
    <header class="nsb-related__head">
      <h3 class="nsb-related__title">{title}</h3>
      <span class="nsb-related__counts" aria-hidden="true">
        {resolved.length > 0 && (
          <span class="nsb-related__count nsb-related__count--resolved">
            {String(resolved.length).padStart(2, "0")} linked
          </span>
        )}
        {unresolved.length > 0 && (
          <span class="nsb-related__count nsb-related__count--pending">
            {String(unresolved.length).padStart(2, "0")} pending
          </span>
        )}
      </span>
    </header>

    {inExpected.length > 0 && (
      <ol class="nsb-related__list">
        {inExpected.map((r) => (
          <li class="nsb-related__item">
            <a class="nsb-related__link" href={r.href} data-accent={r.code.toLowerCase()}>
              <span class="nsb-related__code">
                <span class="nsb-related__code-cat">{CATEGORIES[r.code].shortLabel}</span>
                <span class="nsb-related__code-num">{r.refNum}</span>
              </span>
              <span class="nsb-related__item-title">{r.title}</span>
              <span class="nsb-related__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>
    )}

    {crossCategory.length > 0 && (
      <div class="nsb-related__cross">
        <p class="nsb-eyebrow nsb-related__cross-label">Also relevant</p>
        <ol class="nsb-related__list">
          {crossCategory.map((r) => (
            <li class="nsb-related__item">
              <a class="nsb-related__link" href={r.href} data-accent={r.code.toLowerCase()}>
                <span class="nsb-related__code">
                  <span class="nsb-related__code-cat">{CATEGORIES[r.code].shortLabel}</span>
                  <span class="nsb-related__code-num">{r.refNum}</span>
                </span>
                <span class="nsb-related__item-title">{r.title}</span>
                <span class="nsb-related__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}

    {unresolved.length > 0 && (
      <div class="nsb-related__pending" aria-label="Pending entries">
        <p class="nsb-eyebrow nsb-related__pending-label">
          Pending entries · referenced, not yet authored
        </p>
        <ul class="nsb-related__list nsb-related__list--pending">
          {unresolved.map((u) => (
            <li class="nsb-related__item nsb-related__item--pending">
              <span class="nsb-related__code">
                <span class="nsb-related__code-cat nsb-related__code-cat--pending">— —</span>
                <span class="nsb-related__pending-tag">PEND</span>
              </span>
              <span class="nsb-related__pending-title">{u}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}

<style>
  /* Framed reference panel with black title bar + pill-tag codes.
     Reads as a catalog subsection: black masthead + white list body. */
  .nsb-related {
    margin-top: var(--space-5);
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
  }
  .nsb-related--dense { margin-top: var(--space-4); }

  /* --- Black title bar ------------------------------------------- */
  .nsb-related__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--color-frame);
    color: var(--color-surface);
    border-bottom: 3px solid var(--color-frame);
    flex-wrap: wrap;
  }
  .nsb-related__title {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-yellow);
    margin: 0;
    line-height: 1;
  }
  .nsb-related__counts {
    display: inline-flex;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-feature-settings: "tnum";
  }
  .nsb-related__count--resolved { color: var(--color-surface); }
  .nsb-related__count--pending  { color: var(--color-yellow); opacity: 0.7; }

  /* --- Resolved list -------------------------------------------- */
  .nsb-related__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nsb-related__item { border-top: 2px solid var(--color-frame); }
  .nsb-related__item:first-child { border-top: 0; }

  .nsb-related__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-3) var(--space-5);
    text-decoration: none;
    color: var(--color-ink);
    background: var(--color-surface);
    transition: background var(--dur-fast) var(--ease),
                color var(--dur-fast) var(--ease);
  }
  .nsb-related__link:hover {
    background: var(--color-yellow);
    color: var(--color-yellow-ink);
  }
  .nsb-related__link:hover .nsb-related__arrow { transform: translateX(3px); }

  /* Pill-tag code badge (category + ref num). */
  .nsb-related__code {
    display: inline-flex;
    align-items: center;
    gap: 0;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 0.68rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-feature-settings: "tnum";
    border: 2px solid var(--color-frame);
    overflow: hidden;
  }
  .nsb-related__code-cat {
    background: var(--color-frame);
    color: var(--color-surface);
    padding: 4px 8px;
    line-height: 1;
  }
  .nsb-related__code-num {
    background: var(--color-surface);
    color: var(--color-ink);
    padding: 4px 8px;
    line-height: 1;
    border-left: 2px solid var(--color-frame);
  }
  .nsb-related__link:hover .nsb-related__code-num {
    background: var(--color-yellow);
    color: var(--color-yellow-ink);
  }

  .nsb-related__item-title {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 700;
    color: inherit;
    line-height: var(--leading-snug);
  }
  .nsb-related__arrow {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-lg);
    color: inherit;
    transition: transform var(--dur-fast) var(--ease);
  }

  /* --- Cross-category subgroup ---------------------------------- */
  .nsb-related__cross {
    border-top: 3px solid var(--color-frame);
    background: var(--color-paper-alt);
  }
  .nsb-related__cross-label {
    margin: 0;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
    color: var(--color-ink);
    border-bottom: 2px solid var(--color-frame);
  }

  /* --- Pending subgroup ----------------------------------------- */
  .nsb-related__pending { border-top: 3px solid var(--color-frame); }
  .nsb-related__pending-label {
    margin: 0;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
    color: var(--color-ink);
    background: var(--color-yellow);
    border-bottom: 2px solid var(--color-frame);
  }
  .nsb-related__list--pending { }
  .nsb-related__item--pending {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-3) var(--space-5);
    border-top: 2px solid var(--color-frame);
    background: var(--color-surface);
  }
  .nsb-related__item--pending:first-child { border-top: 0; }
  .nsb-related__code-cat--pending {
    background: var(--color-paper-alt);
    color: var(--color-label);
  }
  .nsb-related__pending-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 0.65rem;
    letter-spacing: var(--tracking-label);
    color: var(--color-surface);
    background: var(--color-red);
    padding: 3px 7px;
    line-height: 1;
    text-transform: uppercase;
    margin-left: var(--space-2);
  }
  .nsb-related__pending-title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-ink-dim);
    line-height: var(--leading-snug);
  }

  @media (max-width: 520px) {
    .nsb-related__link {
      grid-template-columns: auto 1fr;
      gap: var(--space-3);
    }
    .nsb-related__arrow { display: none; }
    .nsb-related__item--pending { grid-template-columns: 1fr; }
  }
</style>
