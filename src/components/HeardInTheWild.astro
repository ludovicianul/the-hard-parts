---
/**
 * HeardInTheWild — FM voice/recognition panel.
 *
 * Hosts `commonQuote` + `whoSaysThis`. Intentionally the one place on the
 * detail page that leans into editorial character: a tinted bulletin panel
 * with a large italic pull-quote and a faded accent quotation mark as
 * typographic ornament. This is the entry's "voice moment" — restrained
 * tabloid energy per docs/design-direction.md, not a blog pull-quote.
 *
 * Renders nothing if there is no quote.
 */

export interface Props {
  quote: string | undefined;
  attribution?: string | undefined;
}

const { quote, attribution } = Astro.props;
const hasQuote = typeof quote === "string" && quote.trim().length > 0;
---
{hasQuote && (
  <section class="fm-voice nsb-plate" aria-label="Heard in the wild">
    <span class="fm-voice__mark" aria-hidden="true">&ldquo;</span>
    <blockquote class="fm-voice__quote">
      <p>{quote}</p>
    </blockquote>
    {attribution && (
      <p class="fm-voice__attribution">
        <span class="nsb-eyebrow fm-voice__attribution-label">Said by</span>
        <span class="fm-voice__attribution-name">{attribution}</span>
      </p>
    )}
  </section>
)}

<style>
  /*
   * The voice panel is the second deliberate DARK editorial plate on the
   * page (the first is the masthead). It bookends the reading experience
   * and gives the entry's "voice moment" print-era presence without being
   * loud. Theme tokens are remapped by the `.nsb-plate` utility so the
   * component is just tuned here for typography and the quotation ornament.
   */
  .fm-voice {
    position: relative;
    margin-top: var(--space-5);
    padding: var(--space-8) var(--space-7) var(--space-6);
    /* Accent-colored top rule cuts across the dark plate. */
    border-top: 3px solid var(--accent-fm-bright);
    overflow: hidden;
  }
  /* Large faded accent open-quote glyph as typographic ornament. */
  .fm-voice__mark {
    position: absolute;
    top: -0.32em;
    left: var(--space-4);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 9rem;
    line-height: 1;
    color: var(--accent-fm-bright);
    opacity: 0.22;
    user-select: none;
    pointer-events: none;
  }
  .fm-voice__quote {
    margin: 0 0 var(--space-5) 0;
    padding-left: var(--space-8);
    border: 0;
    position: relative;
  }
  .fm-voice__quote p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    line-height: var(--leading-snug);
    color: var(--color-on-plate);
    margin: 0;
    max-width: 38rem;
    letter-spacing: 0.005em;
    font-weight: 400;
  }
  .fm-voice__quote p::before { content: ""; }
  .fm-voice__quote p::after {
    content: " \201D";
    color: var(--accent-fm-bright);
    font-style: normal;
    font-weight: 700;
    margin-left: 0.1em;
  }
  .fm-voice__attribution {
    display: inline-flex;
    gap: var(--space-3);
    align-items: baseline;
    padding-left: var(--space-8);
    margin: 0;
  }
  .fm-voice__attribution-label {
    margin: 0;
    /* Bulletin-style label — accent bright on dark. */
    color: var(--accent-fm-bright);
    font-weight: 600;
  }
  .fm-voice__attribution-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-on-plate);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .fm-voice {
      padding: var(--space-7) var(--space-4) var(--space-5);
    }
    .fm-voice__mark { left: var(--space-2); font-size: 6rem; top: -0.28em; }
    .fm-voice__quote { padding-left: var(--space-5); }
    .fm-voice__quote p { font-size: var(--text-lg); }
    .fm-voice__attribution { padding-left: var(--space-5); }
  }
</style>
