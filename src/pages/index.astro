---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EntryCard from "@/components/EntryCard.astro";
import CalloutBand from "@/components/CalloutBand.astro";
import IssueRibbon from "@/components/IssueRibbon.astro";
import Tag from "@/components/Tag.astro";
import { getCurrentIssue } from "@/lib/issues";
import { CATEGORIES, CATEGORY_ORDER } from "@/lib/categories";
import { categoryBlock, listEntries, loadFailureModes, loadTechDecisions, loadRedFlags, loadPlaybooks } from "@/lib/load";
import { formatRefCode } from "@/lib/resolve";
import { ensureValidated } from "@/lib/validate";
import type { SeverityLevel } from "@/lib/attribute-scales";

// Fail the build if content integrity is broken (strict checks only).
ensureValidated();

// Current issue powers two homepage surfaces:
//   1. The "Issue NN" tag in the hero eyebrow (data-derived from
//      the highest-numbered issue in the catalog so the masthead
//      stays in sync automatically).
//   2. The IssueRibbon row rendered between the hero and the
//      "Pick your way in" section, which links to /issues/NN.
//
// Public-surface terminology contract: every UI label that names
// a release uses "Issue NN", never "Edition NN". The internal
// data field on entries is still called `edition` (it's the
// implementation key for the issue→entries relationship), but
// nothing reader-facing exposes that name. See also the
// equivalent labels in `layouts/CategoryLayout.astro` and
// `pages/about.astro`.
//
// Defensive: undefined when no issues exist; both surfaces hide.
const currentIssue = getCurrentIssue();
const issueTagLabel = currentIssue ? currentIssue.label : "Issue";

const cards = CATEGORY_ORDER.map((code) => {
  const meta = categoryBlock(code);
  const count = listEntries(code).length;
  return {
    code,
    route: CATEGORIES[code].route,
    name: meta.name,
    summary: meta.summary,
    count,
    accent: code.toLowerCase() as "fm" | "td" | "rf" | "ep",
  };
});

// Homepage FM preview — six entries chosen to span every FM subcategory
// (planning · people · technical · process · leadership · ai) so the
// preview shows the breadth of the catalog, not a single flavour. One
// card per subcategory keeps the 3×2 grid informative rather than
// redundant. The scope is still one vertical slice: only FM gets a
// preview strip in Phase 2.
const fmEntries = loadFailureModes().entries;
const featuredSlugs = [
  "friendly-rewrite",          // planning
  "hero-trap",                 // people
  "abstraction-addiction",     // technical
  "ticket-theater",            // process
  "invisible-deadline",        // leadership
  "autocomplete-architecture", // ai
];
const fmFeatured = featuredSlugs
  .map((slug) => fmEntries.find((e) => e.slug === slug))
  .filter((e): e is (typeof fmEntries)[number] => e !== undefined);

// Tech Decisions preview — six decisions, one per TD subcategory, same
// editorial intent as the FM preview: show the *breadth* of the axes
// this category spans, not a top-10. Severity-if-wrong drives the card
// weight so a reader can compare FM severity and TD severity-if-wrong
// visually as the same gravity scale.
const tdEntries = loadTechDecisions().entries;
const featuredTdSlugs = [
  "monolith-vs-microservices",            // architecture
  "build-vs-buy",                         // product-delivery
  "specialist-teams-vs-cross-functional-teams", // team-operations
  "test-pyramid-vs-heavy-end-to-end",     // quality-delivery
  "rag-vs-fine-tuning",                   // ai-systems
  "human-in-the-loop-vs-full-automation", // ai-systems (second — highest-signal)
];
const tdFeatured = featuredTdSlugs
  .map((slug) => tdEntries.find((e) => e.slug === slug))
  .filter((e): e is (typeof tdEntries)[number] => e !== undefined);
const tdTotal = tdEntries.length;
const tdRefBySlug = new Map<string, string>();
tdEntries.forEach((e, i) => tdRefBySlug.set(e.slug, formatRefCode("TD", i, tdTotal).refNum));

// Red Flags preview — one entry per LAYER (code, team, process, leadership,
// ai) so the 3×2 grid spans the full primary axis the catalog covers.
// Mirrors the editorial shape of the FM & TD previews: one card per
// axis, not a top-6. Severity drives the card weight as everywhere
// else. The 6th slot surfaces a second high-signal entry from the
// busiest layer (ai) so the grid reads as 3×2 without a blank cell.
const rfEntries = loadRedFlags().entries;
const featuredRfSlugs = [
  "changes-always-touch-too-many-places",                          // code
  "everyone-asks-the-same-person",                                 // team
  "work-enters-faster-than-it-leaves",                             // process
  "reporting-looks-healthier-than-delivery-feels",                 // leadership
  "ai-generated-artifacts-are-trusted-more-than-source-material",  // ai
  "benchmarks-are-discussed-more-than-real-user-outcomes",         // ai (2nd — also AI-quality, highest editorial value)
];
const rfFeatured = featuredRfSlugs
  .map((slug) => rfEntries.find((e) => e.slug === slug))
  .filter((e): e is (typeof rfEntries)[number] => e !== undefined);
const rfRefBySlug = new Map<string, string>();
rfEntries.forEach((e, i) => rfRefBySlug.set(e.slug, formatRefCode("RF", i, rfEntries.length).refNum));

const prettifyRf = (s: string): string =>
  s.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");

// Engineering Playbook preview — one entry per subcategory (delivery,
// team, architecture, operations, ai) so the 3×2 grid spans the full
// subcategory axis the catalog covers. Same editorial shape as FM/TD/RF
// previews. Card weight reflects `difficulty` via the shared severity
// ramp (mapping is identity for low/medium/medium-high/high). The 6th
// slot adds a 2nd AI playbook since AI is the densest and most timely
// subcategory right now.
const epEntries = loadPlaybooks().entries;
const featuredEpSlugs = [
  "run-a-phased-migration",                        // delivery
  "repair-trust-after-a-painful-incident",         // team
  "refactor-a-dangerous-hotspot",                  // architecture
  "run-an-incident-review-that-actually-helps",    // operations
  "upgrade-code-review-for-ai-assisted-work",      // ai
  "evaluate-an-ai-feature-against-real-tasks",     // ai (2nd)
];
const epFeatured = featuredEpSlugs
  .map((slug) => epEntries.find((e) => e.slug === slug))
  .filter((e): e is (typeof epEntries)[number] => e !== undefined);
const epRefBySlug = new Map<string, string>();
epEntries.forEach((e, i) => epRefBySlug.set(e.slug, formatRefCode("EP", i, epEntries.length).refNum));

// Same difficulty → severity-ramp identity mapping the EP landing uses
// so the homepage preview cards carry the same card-fill weight the
// reader will see on the EP landing grid.
const epDifficultyToSev: Record<string, SeverityLevel> = {
  low: "low",
  medium: "medium",
  "medium-high": "medium-high",
  high: "high",
};
const epSeverityFor = (d: string | undefined): SeverityLevel =>
  (d && epDifficultyToSev[d]) || "medium";

const prettifyEp = (s: string): string =>
  s.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
---
<BaseLayout
  title="thehardparts.dev"
  description="The Hard Parts. An engineering reference for recurring software failures, warning signals, hard decisions, and practical playbooks. Four catalogs: Failure Modes, Tech Decisions, Red Flags, and the Engineering Playbook."
>
  <div class="nsb-container nsb-home">
    {/* --------- TABLOID MASTHEAD ---------
        Three-column framed hero inspired by the reference's "TABLOID EDITION"
        front page: black brand rail + giant display headline + stat-card
        rail. All three columns share identical top/bottom padding so their
        internal content baselines (brand code / edition tag / categories
        label) align across the row. Column dividers are drawn by a single
        set of right-borders on the first two columns — no `!important`
        border overrides, no doubled-up rules. */}
    <header class="nsb-home__hero nsb-frame nsb-frame--heavy" aria-label="Masthead">
      {/* Left nameplate — four stacked pieces after the rebrand:
            1. THE HARD PARTS wordmark (yellow, the brand)
            2. ENGINEERING REFERENCE subtitle (white small caps, says
               what the site IS in two words before the section list)
            3. The four section names as a stacked list — the editorial
               table-of-contents treatment.
            4. "Not a framework / Not a methodology / A reference" —
               the three-beat positioning line pinned to the bottom of
               the black rail (margin-top: auto on the style side).
         The old "NOSILVERBULLET" masthead-code line is replaced by the
         new two-line wordmark+subtitle block so the rail reads as a
         real nameplate, not as a small eyebrow code. */}
      <div class="nsb-home__hero-brand nsb-home__hero-col">
        <div class="nsb-home__hero-wordmark">
          <p class="nsb-home__hero-wordmark-name">The Hard Parts</p>
          <p class="nsb-home__hero-wordmark-sub">Engineering reference</p>
        </div>
        <ul class="nsb-home__hero-brand-list">
          <li>Failure modes.</li>
          <li>Red flags.</li>
          <li>Trade-offs.</li>
          <li>Playbooks.</li>
        </ul>
        <p class="nsb-home__hero-brand-note">
          Not a framework.<br />
          Not a methodology.<br />
          A reference.
        </p>
      </div>

      {/* Center column — Issue tag eyebrow + headline + supporting
          copy. The eyebrow Tag now reads from `getCurrentIssue()`
          so it stays in sync with the highest-numbered issue in
          the catalog (no more hardcoded "Edition 01" string). */}
      <div class="nsb-home__hero-title-col nsb-home__hero-col">
        <div class="nsb-home__hero-eyebrow">
          <Tag label={issueTagLabel} variant="yellow" size="sm" />
        </div>
        <h1 class="nsb-display nsb-display--xl nsb-home__hero-title">
          Software fails<br />the same way.<br />Every time.
        </h1>
        <p class="nsb-home__hero-summary">
          A reference for recurring software failures, warning
          signals, hard decisions, and practical playbooks.
        </p>
      </div>

      {/* Stats rail — three equal-height cells stacked at desktop, each
          sharing the rail's own uniform padding so their labels/values
          align with the center column's content. Yellow and blue are
          signal colors (not category colors), so they can stay loud
          without overloading category meaning. The note cell carries
          a short usage directive — a reader sees at a glance how the
          reference is meant to be used (retros, reviews, decisions),
          not what it is (that's the left and center columns' job). */}
      <div class="nsb-home__hero-stats" aria-label="Catalog stats">
        <div class="nsb-home__hero-stat nsb-home__hero-stat--yellow">
          <p class="nsb-home__hero-stat-label">Sections</p>
          <p class="nsb-home__hero-stat-value nsb-stat-num">
            {String(CATEGORY_ORDER.length).padStart(2, "0")}
          </p>
        </div>
        <div class="nsb-home__hero-stat nsb-home__hero-stat--blue">
          <p class="nsb-home__hero-stat-label">Entries</p>
          <p class="nsb-home__hero-stat-value nsb-stat-num">
            {String(cards.reduce((sum, c) => sum + c.count, 0)).padStart(2, "0")}
          </p>
        </div>
        <div class="nsb-home__hero-stat nsb-home__hero-stat--note">
          <p class="nsb-home__hero-note-head">Open. Use.</p>
          <ul class="nsb-home__hero-note-list">
            <li>Use in retros.</li>
            <li>Use in reviews.</li>
            <li>Use in decisions.</li>
          </ul>
        </div>
      </div>
    </header>

    {/* --------- CURRENT ISSUE RIBBON ---------
        Sits between the masthead and the category map so the latest
        public release announcement is the first beat a returning
        reader hits. Data-derived from the highest-numbered issue in
        the catalog; renders nothing if no issues exist (defensive).
        For Issue 01 (today) the ribbon reads as an inaugural
        introduction; for Issue 02+ it auto-flips into changelog
        framing — see IssueRibbon.astro for the cta/beats logic. */}
    {currentIssue && <IssueRibbon issue={currentIssue} />}

    {/* --------- CATEGORY MAP ---------
        Four framed cards, each with a saturated header strip. The head
        color is driven by the per-category --accent-current variable
        set via `data-accent`, so the palette is defined in exactly one
        place (tokens.css §Category accents) and cascades everywhere
        that reads --accent-current (detail masthead, arc accents,
        related-entries frames, etc.). */}
    <section class="nsb-home__grid" aria-label="Categories">
      {cards.map((c) => (
        <a class="nsb-home__card nsb-frame" href={`/${c.route}`} data-accent={c.accent}>
          <div class="nsb-home__card-head">
            <span class="nsb-home__card-code">{c.code}</span>
            <span class="nsb-home__card-count">{String(c.count).padStart(2, "0")} entries</span>
          </div>
          <div class="nsb-home__card-body">
            <h2 class="nsb-home__card-title">{c.name}</h2>
            <p class="nsb-home__card-summary">{c.summary}</p>
          </div>
        </a>
      ))}
    </section>

    {/* --------- PICK YOUR WAY IN ---------
        First-time visitors need a fast "which section matches what I'm
        feeling right now" cue. Four one-line prompts keyed to the four
        categories, rendered as a compact yellow-eyebrow panel. Each
        prompt is a link straight to that category's landing page, so
        "I've seen this go wrong before" lands the reader on FM in one
        click. Explicit editorial voice: no persona pitches, no badges,
        no onboarding cards — just four question/answer pairs. */}
    <section class="nsb-home__orient" aria-label="Pick your way in">
      <header class="nsb-home__orient-head">
        <span class="nsb-home__orient-eyebrow">Pick your way in</span>
        <h2 class="nsb-home__orient-title">Start from the question you have</h2>
      </header>
      <ul class="nsb-home__orient-list">
        <li class="nsb-home__orient-item" data-accent="fm">
          <a href="/failure-modes" class="nsb-home__orient-link">
            <span class="nsb-home__orient-q">I&rsquo;ve seen this project go wrong before. What am I looking at?</span>
            <span class="nsb-home__orient-a">
              <span class="nsb-home__orient-code">FM</span>
              <span class="nsb-home__orient-name">Failure Modes</span>
              <span class="nsb-home__orient-arrow" aria-hidden="true">&rarr;</span>
            </span>
          </a>
        </li>
        <li class="nsb-home__orient-item" data-accent="td">
          <a href="/tech-decisions" class="nsb-home__orient-link">
            <span class="nsb-home__orient-q">What trade-off am I actually making here, and on what?</span>
            <span class="nsb-home__orient-a">
              <span class="nsb-home__orient-code">TD</span>
              <span class="nsb-home__orient-name">Tech Decisions</span>
              <span class="nsb-home__orient-arrow" aria-hidden="true">&rarr;</span>
            </span>
          </a>
        </li>
        <li class="nsb-home__orient-item" data-accent="rf">
          <a href="/red-flags" class="nsb-home__orient-link">
            <span class="nsb-home__orient-q">Something about this feels off. What am I noticing?</span>
            <span class="nsb-home__orient-a">
              <span class="nsb-home__orient-code">RF</span>
              <span class="nsb-home__orient-name">Red Flags</span>
              <span class="nsb-home__orient-arrow" aria-hidden="true">&rarr;</span>
            </span>
          </a>
        </li>
        <li class="nsb-home__orient-item" data-accent="ep">
          <a href="/engineering-playbook" class="nsb-home__orient-link">
            <span class="nsb-home__orient-q">I know the situation. What&rsquo;s the right way to run it?</span>
            <span class="nsb-home__orient-a">
              <span class="nsb-home__orient-code">EP</span>
              <span class="nsb-home__orient-name">Engineering Playbook</span>
              <span class="nsb-home__orient-arrow" aria-hidden="true">&rarr;</span>
            </span>
          </a>
        </li>
      </ul>
    </section>

    {fmFeatured.length > 0 && (
      <section class="nsb-home__preview" aria-label="From Failure Modes" data-accent="fm">
        <CalloutBand label="Field guide" variant="yellow">
          <p>Failure Modes: named patterns that recur in software teams.</p>
        </CalloutBand>

        <header class="nsb-home__preview-header">
          <h2 class="nsb-display nsb-home__preview-title">From Failure Modes</h2>
          <p class="nsb-home__preview-note">
            A glimpse of the catalog. Each entry walks through how the
            pattern starts, how it escalates, what it looks like at early,
            mid, and late stages, and what good responses look like.
          </p>
        </header>

        <div class="nsb-home__preview-grid">
          {fmFeatured.map((e) => (
            /* Same severity-driven fill rule as the FM landing catalog —
               preview strip mirrors the big grid so readers see the same
               color contract everywhere. */
            <EntryCard
              code="FM"
              slug={e.slug}
              title={e.title}
              summary={e.summary}
              subcategory={e.category}
              severity={e.severity as "low" | "medium" | "medium-high" | "high" | "critical"}
              refNum={String(fmEntries.findIndex((x) => x.slug === e.slug) + 1).padStart(3, "0")}
              fillFromSeverity
              metaBits={[`Freq · ${e.frequency}`]}
            />
          ))}
        </div>

        <p class="nsb-home__preview-more">
          <a href="/failure-modes" class="nsb-home__preview-link">
            Browse all {fmEntries.length} Failure Modes &rarr;
          </a>
        </p>
      </section>
    )}

    {tdFeatured.length > 0 && (
      /* TD preview mirrors the FM preview's shape — same CalloutBand
         header, same preview-grid card layout, same "Browse all …" tail
         link — so the two categories read as siblings of the same
         editorial system. `data-accent="td"` scopes --accent-current
         to burnt orange for this whole section: any child that reads
         `var(--accent-current)` (card hover underline, link hover
         state, etc.) picks up TD's hue without extra wiring. */
      <section class="nsb-home__preview" aria-label="From Tech Decisions" data-accent="td">
        <CalloutBand label="Decision ledger" variant="yellow">
          <p>Tech Decisions: structured trade-off references for consequential engineering calls.</p>
        </CalloutBand>

        <header class="nsb-home__preview-header">
          <h2 class="nsb-display nsb-home__preview-title">From Tech Decisions</h2>
          <p class="nsb-home__preview-note">
            One decision per axis the catalog covers: architecture,
            delivery, team, quality, and AI systems. Each entry lays out
            two concrete options with their real conditions, costs,
            hidden costs, and failure modes when misapplied.
          </p>
        </header>

        <div class="nsb-home__preview-grid">
          {tdFeatured.map((e) => (
            <EntryCard
              code="TD"
              slug={e.slug}
              title={e.title}
              summary={e.summary}
              subcategory={e.category}
              severity={(e.severityIfWrong ?? "medium") as SeverityLevel}
              refNum={tdRefBySlug.get(e.slug)}
              fillFromSeverity
              metaBits={[
                /* Mirrors the TD landing: Reversibility is surfaced on the
                   detail MetaRail, not duplicated on the card eyebrow. */
                e.frequency ? `Freq · ${e.frequency}` : undefined,
              ].filter((s): s is string => typeof s === "string")}
            />
          ))}
        </div>

        <p class="nsb-home__preview-more">
          <a href="/tech-decisions" class="nsb-home__preview-link">
            Browse all {tdEntries.length} Tech Decisions &rarr;
          </a>
        </p>
      </section>
    )}

    {rfFeatured.length > 0 && (
      /* Red Flags preview — siblings the FM & TD preview sections in
         structure (CalloutBand + grid + browse-all tail), but scoped
         with `data-accent="rf"` so anything that reads
         `var(--accent-current)` inside this section (card hover
         underline, link hover) picks up crimson instead of yellow or
         burnt orange. Card meta surfaces `Detect · …` — the RF-
         distinct dimension — instead of a second severity-style pill. */
      <section class="nsb-home__preview" aria-label="From Red Flags" data-accent="rf">
        <CalloutBand label="Signal bulletin" variant="yellow">
          <p>Red Flags: early-warning signals across code, teams, process, leadership, and AI-enabled work.</p>
        </CalloutBand>

        <header class="nsb-home__preview-header">
          <h2 class="nsb-display nsb-home__preview-title">From Red Flags</h2>
          <p class="nsb-home__preview-note">
            One signal per layer the catalog covers: code, team,
            process, leadership, and AI. Each entry opens with
            <em>what you would actually notice</em> and walks through what
            it usually indicates and what to check next.
          </p>
        </header>

        <div class="nsb-home__preview-grid">
          {rfFeatured.map((e) => (
            <EntryCard
              code="RF"
              slug={e.slug}
              title={e.title}
              summary={e.summary}
              subcategory={prettifyRf(e.signalType)}
              severity={e.severity as SeverityLevel}
              refNum={rfRefBySlug.get(e.slug)}
              fillFromSeverity
              metaBits={[
                /* Frequency, not detectability — mirrors the RF landing
                   cards and the FM/TD preview cards so all three preview
                   strips carry the same eyebrow vocabulary. Detectability
                   is a first-class dimension on the RF detail MetaRail. */
                e.frequency ? `Freq · ${e.frequency}` : undefined,
              ].filter((s): s is string => typeof s === "string")}
            />
          ))}
        </div>

        <p class="nsb-home__preview-more">
          <a href="/red-flags" class="nsb-home__preview-link">
            Browse all {rfEntries.length} Red Flags &rarr;
          </a>
        </p>
      </section>
    )}

    {epFeatured.length > 0 && (
      /* Engineering Playbook preview — sibling of the FM/TD/RF preview
         sections. `data-accent="ep"` scopes --accent-current to plum
         purple so anything reading `var(--accent-current)` inside this
         block (card hover underlines, link hovers) picks up EP's
         identity hue. Card meta carries `Owner · …` — same "is this
         for me?" signal the EP landing cards use — so the homepage
         preview and the landing grid read as one continuous catalog. */
      <section class="nsb-home__preview" aria-label="From Engineering Playbook" data-accent="ep">
        <CalloutBand label="Operating manual" variant="yellow">
          <p>Engineering Playbook: structured procedures for recurring engineering situations.</p>
        </CalloutBand>

        <header class="nsb-home__preview-header">
          <h2 class="nsb-display nsb-home__preview-title">From Engineering Playbook</h2>
          <p class="nsb-home__preview-note">
            One playbook per subcategory the catalog covers: delivery,
            team, architecture, operations, and AI adoption.
            Each entry opens with <em>when to use it</em>,
            <em>when not to</em>, and walks you through the steps,
            common mistakes, and signals that it actually landed.
          </p>
        </header>

        <div class="nsb-home__preview-grid">
          {epFeatured.map((e) => (
            /* Owner role rendered as a plain meta bit (no "Owner · "
               prefix) to match the EP landing cards. The role name
               itself ("tech lead", "engineering manager", etc.) is
               unambiguous; the eyebrow label was visual noise. */
            <EntryCard
              code="EP"
              slug={e.slug}
              title={e.title}
              summary={e.summary}
              subcategory={prettifyEp(e.category)}
              severity={epSeverityFor(e.difficulty)}
              refNum={epRefBySlug.get(e.slug)}
              fillFromSeverity
              metaBits={[e.primaryOwner].filter(
                (s): s is string => typeof s === "string" && s.length > 0,
              )}
            />
          ))}
        </div>

        <p class="nsb-home__preview-more">
          <a href="/engineering-playbook" class="nsb-home__preview-link">
            Browse all {epEntries.length} Playbooks &rarr;
          </a>
        </p>
      </section>
    )}

    {/* Closer — replaces the earlier dev-framing "Phase status" aside.
        A three-beat working motto panel that echoes the product brief
        without sliding into marketing copy. Left column is the framed
        black ID strip the rest of the site uses (see section mastheads,
        related-entry heads); right column is the motto pair in serif. */}
    <aside class="nsb-home__closer" aria-label="Working motto">
      <div class="nsb-home__closer-code">
        <span class="nsb-home__closer-code-cat">T H P</span>
        <span class="nsb-home__closer-code-num">&middot; 01</span>
      </div>
      <div class="nsb-home__closer-body">
        <p class="nsb-home__closer-lede">
          Software is hard. The patterns repeat.
        </p>
        <p class="nsb-home__closer-motto">
          Name the patterns. Show the trade-offs.<br />
          Surface the signals. Make the useful path visible.
        </p>
      </div>
    </aside>
  </div>

  <style>
    .nsb-home { padding-block: var(--space-6) var(--space-9); }

    /* ================================================================
       TABLOID MASTHEAD (reference image 1 direction)
       ================================================================ */
    .nsb-home__hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      margin-bottom: var(--space-8);
    }
    @media (min-width: 900px) {
      .nsb-home__hero {
        grid-template-columns: minmax(12rem, 16rem) minmax(0, 1fr) minmax(13rem, 18rem);
      }
    }

    /* Shared hero column: identical padding on all three grid children
       so the first paint line of each column's content (NOSILVERBULLET
       / EDITION 01 / CATEGORIES) sits at the same y-offset from the
       top of the hero frame. Previously each column set its own padding
       and the Categories label landed higher than the EDITION 01 tag,
       which read as a vertical misalignment. */
    .nsb-home__hero-col {
      padding: var(--space-6) var(--space-5);
      min-width: 0;
    }
    @media (min-width: 900px) {
      .nsb-home__hero-brand,
      .nsb-home__hero-title-col {
        border-right: 3px solid var(--color-frame);
      }
    }
    @media (max-width: 899px) {
      .nsb-home__hero-brand,
      .nsb-home__hero-title-col {
        border-bottom: 3px solid var(--color-frame);
      }
    }

    /* Left nameplate rail — black to continue the tabloid masthead from
       the top nav bar. Yellow brand code + white body type on black
       reads as "masthead", not "alert" (the old red version collided
       with red=critical on FM cards). Flex-column so the tagline can
       use `margin-top: auto` to pin itself to the bottom of the rail
       regardless of how tall the center column pushes the hero. */
    .nsb-home__hero-brand {
      background: var(--color-frame);
      color: var(--color-surface);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      min-height: 100%;
    }
    /* Two-line wordmark block: the site name (yellow, display size
       on the rail — sits in the same y-slot where NOSILVERBULLET
       used to live as a small eyebrow) over a small-caps subtitle
       on white. The name doubles as the editorial masthead of the
       left rail; the subtitle compacts "what this is" into two
       words before the section list takes over. Sized to be clearly
       the second-largest element on the page after the center
       headline, without competing with it. */
    .nsb-home__hero-wordmark {
      display: flex;
      flex-direction: column;
      gap: 2px;
      margin-bottom: var(--space-2);
    }
    .nsb-home__hero-wordmark-name {
      margin: 0;
      font-family: var(--font-sans);
      font-weight: 900;
      /* Mobile floor raised (1.25rem → 1.65rem) so the brand reads
         as the anchor of the left rail when the hero stacks. The
         vw factor stays moderate so on desktop it still settles
         well under the headline's display size and the visual
         hierarchy (headline > brand) is preserved. */
      font-size: clamp(1.65rem, 5vw, 1.85rem);
      line-height: 1.05;
      letter-spacing: -0.015em;
      text-transform: uppercase;
      color: var(--color-yellow);
    }
    .nsb-home__hero-wordmark-sub {
      margin: 0;
      font-family: var(--font-sans);
      font-weight: 800;
      /* Bumped from --text-xs (12.75px) to --text-sm (14.875px) so
         the subtitle stays in proportion with the larger name above. */
      font-size: var(--text-sm);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-surface);
      opacity: 0.78;
    }
    /* The four section names as a stacked list — the new "nameplate"
       for the left rail. Sized to read as the dominant element on the
       rail without competing with the center headline. Each line ends
       in a period (by content) so the list scans as a series of beats,
       not a bulleted nav menu. */
    .nsb-home__hero-brand-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
      font-family: var(--font-sans);
      font-weight: 900;
      /* Floor raised from 1.1rem to 1.4rem so the four-beat section
         list (Failure modes. Red flags. Trade-offs. Playbooks.) carries
         enough weight on mobile to balance the giant headline that
         appears in the column below. Desktop cap unchanged. */
      font-size: clamp(1.4rem, 4vw, 1.55rem);
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--color-surface);
    }
    .nsb-home__hero-brand-list li { margin: 0; }
    /* Three-beat positioning tagline — sits at the BOTTOM of the
       black rail (margin-top: auto) so the left column reads as a
       nameplate (code + list) on top and a caption on the bottom,
       instead of everything clumping at the top with a tall black
       void below. Italic serif at body size, same treatment as the
       old brand-note. */
    .nsb-home__hero-brand-note {
      margin: auto 0 0 0;
      padding-top: var(--space-5);
      font-family: var(--font-serif);
      font-style: italic;
      font-size: var(--text-sm);
      color: var(--color-surface);
      opacity: 0.78;
      line-height: 1.35;
    }

    /* Center title column — big display headline. Padding comes from
       the shared `.nsb-home__hero-col` rule above so its first content
       line aligns with the other two columns. */
    .nsb-home__hero-title-col {
      background: var(--color-surface);
    }
    .nsb-home__hero-eyebrow {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
      font-family: var(--font-sans);
      font-weight: 800;
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-label);
      flex-wrap: wrap;
    }
    .nsb-home__hero-title {
      color: var(--color-ink);
      margin: 0;
      /* Cap lowered from 4rem → 3.25rem: the new 4-line headline
         ("Software / fails / the same way. / Every time.") is taller
         than the old one, and at 4rem it was driving the whole hero
         so tall that the side rails stretched into uncomfortable
         voids. 3.25rem keeps the display feeling oversized without
         inflating the overall hero height.
         `overflow-wrap: anywhere` stays as a safety net. */
      font-size: clamp(2rem, 5.4vw, 3.25rem);
      line-height: 0.94;
      overflow-wrap: anywhere;
      hyphens: none;
    }
    .nsb-home__hero-summary {
      font-family: var(--font-serif);
      font-size: clamp(var(--text-md), 1.6vw, var(--text-lg));
      color: var(--color-ink-dim);
      line-height: var(--leading-snug);
      margin: var(--space-5) 0 0 0;
    }

    /* Stats rail — three equal-height cells. The rail is a grid so
       the cells stretch to fill the rail's vertical space equally
       (important when the rail's total height is driven by the giant
       headline in the center column — otherwise the rail would have
       an unlabeled trailing gap below the note). At mobile the rail
       stacks horizontally to two columns; the note drops to a full-
       width row underneath. */
    .nsb-home__hero-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }
    @media (min-width: 900px) {
      .nsb-home__hero-stats {
        grid-template-columns: 1fr;
        /* Three equal rows so all three cells stretch to the same
           height. The previous `1fr 1fr auto` let the two stat cells
           swallow the space and left the "Open. Share." note cell
           awkwardly squat. Equal rows = balanced rail. */
        grid-template-rows: 1fr 1fr 1fr;
      }
    }
    /* Each stat cell — same padding as the hero columns so the label
       inside lines up with EDITION 01 / NOSILVERBULLET in the other
       two columns. Width fills the cell (no own border, no min-width);
       dividers between cells are drawn by their own box edges. */
    .nsb-home__hero-stat {
      padding: var(--space-6) var(--space-5);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: var(--space-3);
      min-width: 0;
    }
    .nsb-home__hero-stat--yellow {
      background: var(--color-yellow);
      color: var(--color-yellow-ink);
    }
    .nsb-home__hero-stat--blue {
      background: var(--color-blue);
      color: var(--color-surface);
    }
    .nsb-home__hero-stat--note {
      background: var(--color-yellow);
      color: var(--color-yellow-ink);
      /* The note is a caption, not a number — it stays a single
         flex child with its text vertically centered for balance
         rather than top-anchored like the stat cells. */
      justify-content: center;
      grid-column: 1 / -1;
    }
    @media (min-width: 900px) {
      .nsb-home__hero-stat--note { grid-column: auto; }
    }
    /* Dividers between stat cells — bottom borders at desktop (stacked),
       right borders at mobile (two-up). Only the first-row cells get
       them; the last cell never has a divider so the rail meets the
       outer hero frame cleanly. */
    @media (min-width: 900px) {
      .nsb-home__hero-stat:not(:last-child) {
        border-bottom: 3px solid var(--color-frame);
      }
    }
    @media (max-width: 899px) {
      .nsb-home__hero-stat--yellow { border-right: 3px solid var(--color-frame); }
      .nsb-home__hero-stat--blue   { border-bottom: 3px solid var(--color-frame); }
      .nsb-home__hero-stat--yellow { border-bottom: 3px solid var(--color-frame); }
    }
    .nsb-home__hero-stat-label {
      margin: 0;
      font-family: var(--font-sans);
      font-weight: 800;
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: inherit;
    }
    .nsb-home__hero-stat-value {
      margin: 0;
      color: inherit;
    }
    /* Usage directive inside the note cell. `note-head` is the short
       "Open. Share." lead-in at body-weight size; `note-list` is the
       stacked "Use in retros / reviews / decisions" beats in a slightly
       smaller, dimmer style so the lead-in reads first. Both stay on
       the yellow background (no border separator) so the cell reads
       as a single editorial paragraph, not a card inside a card. */
    .nsb-home__hero-note-head {
      margin: 0;
      font-family: var(--font-sans);
      font-weight: 900;
      font-size: var(--text-md);
      letter-spacing: -0.01em;
      line-height: var(--leading-snug);
      color: inherit;
    }
    .nsb-home__hero-note-list {
      margin: var(--space-2) 0 0 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 2px;
      font-family: var(--font-sans);
      font-weight: 700;
      font-size: var(--text-sm);
      line-height: var(--leading-snug);
      color: inherit;
      opacity: 0.85;
    }
    .nsb-home__hero-note-list li { margin: 0; }

    /* ================================================================
       CATEGORY MAP — framed cards with colored header strips.
       Locked to a balanced 2×2 block at any desktop-ish width so the
       four cards breathe (4-across squeezes the titles). Stacks into
       one column on narrow screens.
       ================================================================ */
    .nsb-home__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
      margin-bottom: var(--space-9);
    }
    @media (min-width: 640px) {
      .nsb-home__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    .nsb-home__card {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      background: var(--color-surface);
      transition: transform var(--dur-fast) var(--ease),
                  box-shadow var(--dur-fast) var(--ease);
      min-height: 12rem;
    }
    .nsb-home__card:hover,
    .nsb-home__card:focus-visible {
      transform: translate(-3px, -3px);
      box-shadow: 6px 6px 0 0 var(--color-frame);
      outline: none;
    }
    .nsb-home__card-head {
      padding: var(--space-3) var(--space-5);
      border-bottom: 3px solid var(--color-frame);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      font-family: var(--font-sans);
      font-weight: 900;
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      font-size: var(--text-xs);
      /* One rule fits all four categories — the parent <a data-accent>
         scopes --accent-current to the right per-category hue. All four
         category accents are saturated enough to take white text. */
      background: var(--accent-current);
      color: var(--color-surface);
    }
    .nsb-home__card-code { font-size: var(--text-sm); }
    .nsb-home__card-count { opacity: 0.75; font-feature-settings: "tnum"; }
    .nsb-home__card-body {
      padding: var(--space-5);
      flex: 1 1 auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .nsb-home__card-title {
      font-family: var(--font-sans);
      font-size: clamp(var(--text-xl), 2.4vw, var(--text-2xl));
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 1;
      margin: 0;
      color: var(--color-ink);
    }
    .nsb-home__card-summary {
      font-family: var(--font-serif);
      color: var(--color-ink-dim);
      font-size: var(--text-base);
      line-height: var(--leading-snug);
      margin: 0;
    }

    /* ================================================================
       FM PREVIEW SECTION
       ================================================================ */
    .nsb-home__preview { margin-bottom: var(--space-9); }
    .nsb-home__preview-header { margin-bottom: var(--space-5); }
    .nsb-home__preview-title {
      font-size: clamp(var(--text-3xl), 5vw, 3.5rem);
      margin: 0;
      color: var(--color-ink);
    }
    .nsb-home__preview-note {
      font-family: var(--font-serif);
      color: var(--color-ink-dim);
      font-size: var(--text-md);
      line-height: var(--leading-snug);
      margin: var(--space-3) 0 0 0;
    }
    .nsb-home__preview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: var(--space-4);
    }
    .nsb-home__preview-more {
      margin: var(--space-5) 0 0 0;
      font-family: var(--font-sans);
      font-size: var(--text-sm);
      font-weight: 800;
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
    }
    .nsb-home__preview-link {
      display: inline-block;
      padding: 8px 14px;
      background: var(--color-frame);
      color: var(--color-surface);
      text-decoration: none;
      border: 2px solid var(--color-frame);
    }
    .nsb-home__preview-link:hover {
      background: var(--color-yellow);
      color: var(--color-yellow-ink);
    }

    /* ================================================================
       PICK YOUR WAY IN — orientation panel between the category map
       and the per-category preview strips. Four question/answer rows
       in a single framed panel. Each row's left side is the editorial
       question a reader might arrive with; the right side is the
       shortcut into that category. On hover, the accent-colored code
       box flips to yellow so the four categories' identity hues are
       still visible in their resting state. Matches the tabloid
       "black frame, yellow signal" vocabulary used elsewhere.
       ================================================================ */
    .nsb-home__orient {
      margin-top: var(--space-7);
      margin-bottom: var(--space-7);
      background: var(--color-surface);
      border: 3px solid var(--color-frame);
    }
    .nsb-home__orient-head {
      padding: var(--space-4) var(--space-5) var(--space-3);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-3);
      align-items: baseline;
      background: var(--color-frame);
      color: var(--color-surface);
    }
    .nsb-home__orient-eyebrow {
      font-family: var(--font-sans);
      font-weight: 900;
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-yellow);
    }
    .nsb-home__orient-title {
      font-family: var(--font-sans);
      font-weight: 900;
      letter-spacing: -0.01em;
      font-size: clamp(var(--text-lg), 2.2vw, var(--text-xl));
      line-height: 1.1;
      color: var(--color-surface);
      margin: 0;
    }
    .nsb-home__orient-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .nsb-home__orient-item {
      border-top: 2px solid var(--color-frame);
    }
    .nsb-home__orient-item:first-child {
      border-top: 0;
    }
    .nsb-home__orient-link {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--space-4);
      align-items: center;
      padding: var(--space-4) var(--space-5);
      text-decoration: none;
      color: var(--color-ink);
      background: var(--color-surface);
      transition: background var(--dur-fast) var(--ease);
    }
    .nsb-home__orient-link:hover {
      background: var(--color-yellow);
      color: var(--color-yellow-ink);
    }
    .nsb-home__orient-q {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      font-style: italic;
      line-height: var(--leading-snug);
      color: inherit;
    }
    .nsb-home__orient-a {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      font-family: var(--font-sans);
      font-weight: 900;
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      font-size: var(--text-xs);
      color: inherit;
      white-space: nowrap;
    }
    .nsb-home__orient-code {
      display: inline-block;
      padding: 4px 8px;
      background: var(--accent-current);
      color: var(--color-surface);
      font-family: var(--font-sans);
      font-weight: 900;
      font-feature-settings: "tnum";
      letter-spacing: var(--tracking-label);
    }
    .nsb-home__orient-link:hover .nsb-home__orient-code {
      background: var(--color-frame);
      color: var(--color-yellow);
    }
    .nsb-home__orient-name {
      color: inherit;
    }
    .nsb-home__orient-arrow {
      font-family: var(--font-sans);
      font-weight: 900;
      font-size: var(--text-base);
      color: inherit;
      transition: transform var(--dur-fast) var(--ease);
    }
    .nsb-home__orient-link:hover .nsb-home__orient-arrow {
      transform: translateX(3px);
    }
    @media (max-width: 640px) {
      .nsb-home__orient-head {
        grid-template-columns: 1fr;
        gap: var(--space-2);
      }
      .nsb-home__orient-link {
        grid-template-columns: 1fr;
        gap: var(--space-2);
        align-items: start;
      }
      .nsb-home__orient-a {
        justify-content: flex-end;
      }
    }

    /* ================================================================
       CLOSER — replaces the earlier dev "Phase status" aside. A
       two-part strip: the reference code plate on the left, the
       working motto serif pair on the right. Short, editorial,
       deliberately not a marketing banner.
       ================================================================ */
    .nsb-home__closer {
      margin-top: var(--space-7);
      background: var(--color-surface);
      border: 3px solid var(--color-frame);
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: stretch;
    }
    .nsb-home__closer-code {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-5);
      background: var(--color-frame);
      color: var(--color-yellow);
      font-family: var(--font-sans);
      font-weight: 900;
      letter-spacing: var(--tracking-label);
      font-size: var(--text-xs);
      text-transform: uppercase;
      white-space: nowrap;
    }
    .nsb-home__closer-code-cat { color: var(--color-yellow); }
    .nsb-home__closer-code-num {
      color: var(--color-surface);
      opacity: 0.7;
      font-feature-settings: "tnum";
    }
    .nsb-home__closer-body {
      padding: var(--space-4) var(--space-5);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .nsb-home__closer-lede {
      margin: 0;
      font-family: var(--font-sans);
      font-weight: 900;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      font-size: clamp(var(--text-base), 1.6vw, var(--text-lg));
      color: var(--color-ink);
      line-height: 1.1;
    }
    .nsb-home__closer-motto {
      margin: 0;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: var(--text-sm);
      line-height: var(--leading-snug);
      color: var(--color-ink-dim);
    }
    @media (max-width: 640px) {
      .nsb-home__closer {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
