---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EntryCard from "@/components/EntryCard.astro";
import { CATEGORIES, CATEGORY_ORDER } from "@/lib/categories";
import { categoryBlock, listEntries, loadFailureModes } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";

// Fail the build if content integrity is broken (strict checks only).
ensureValidated();

const cards = CATEGORY_ORDER.map((code) => {
  const meta = categoryBlock(code);
  const count = listEntries(code).length;
  return {
    code,
    route: CATEGORIES[code].route,
    name: meta.name,
    summary: meta.summary,
    count,
    accent: code.toLowerCase() as "fm" | "td" | "rf" | "ep",
  };
});

// Homepage FM preview — four entries chosen by editorial priority to span
// four different FM subcategories (planning · people · technical · ai) so
// the preview shows breadth, not a single flavour. The scope is one
// vertical slice: only FM gets a preview strip in Phase 2.
const fmEntries = loadFailureModes().entries;
const featuredSlugs = [
  "friendly-rewrite",        // planning
  "hero-trap",               // people
  "abstraction-addiction",   // technical
  "autocomplete-architecture", // ai
];
const fmFeatured = featuredSlugs
  .map((slug) => fmEntries.find((e) => e.slug === slug))
  .filter((e): e is (typeof fmEntries)[number] => e !== undefined);
---
<BaseLayout
  title="nosilverbullet.dev"
  description="A reference-first field guide for software people. Failure Modes, Tech Decisions, Red Flags, and the Engineering Playbook."
>
  <div class="nsb-container nsb-home">
    <header class="nsb-home__hero">
      <p class="nsb-eyebrow">nosilverbullet.dev</p>
      <h1 class="nsb-home__title">
        Software is hard. That’s the point.
      </h1>
      <p class="nsb-home__summary">
        A reference-first field guide to how software work goes wrong, how
        engineers make trade-offs, what to watch for early, and what good
        looks like when things are hard.
      </p>
    </header>

    <section class="nsb-home__grid" aria-label="Categories">
      {cards.map((c) => (
        <a class="nsb-home__card" href={`/${c.route}`} data-accent={c.accent}>
          <p class="nsb-eyebrow">{c.code}</p>
          <h2 class="nsb-home__card-title">{c.name}</h2>
          <p class="nsb-home__card-summary">{c.summary}</p>
          <p class="nsb-home__card-count">{c.count} entries</p>
        </a>
      ))}
    </section>

    {fmFeatured.length > 0 && (
      <section class="nsb-home__preview" aria-label="From Failure Modes" data-accent="fm">
        <header class="nsb-home__preview-header">
          <p class="nsb-eyebrow">FM · from the field guide</p>
          <h2 class="nsb-home__preview-title">From Failure Modes</h2>
          <p class="nsb-home__preview-note">
            A glimpse of the catalog. Each entry walks through how the
            pattern starts, how it escalates, what it looks like at early,
            mid, and late stages, and what good responses look like.
          </p>
        </header>

        <div class="nsb-home__preview-grid">
          {fmFeatured.map((e) => (
            <EntryCard
              code="FM"
              slug={e.slug}
              title={e.title}
              summary={e.summary}
              subcategory={e.category}
              metaBits={[
                `severity · ${e.severity}`,
                `frequency · ${e.frequency}`,
              ]}
            />
          ))}
        </div>

        <p class="nsb-home__preview-more">
          <a href="/failure-modes" class="nsb-home__preview-link">
            Browse all {fmEntries.length} Failure Modes →
          </a>
        </p>
      </section>
    )}

    <aside class="nsb-home__status" aria-label="Build status">
      <p class="nsb-eyebrow">Phase status</p>
      <p class="nsb-home__status-text">
        Failure Modes is the first category wired end-to-end with real
        detail pages, warning-signs-by-stage rendering, and cross-reference
        resolution. Tech Decisions, Red Flags, and Engineering Playbook
        follow the same template in later phases.
      </p>
    </aside>
  </div>

  <style>
    .nsb-home { padding-block: var(--space-6) var(--space-8); }
    .nsb-home__hero { margin-bottom: var(--space-8); }
    .nsb-home__title {
      font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
      max-width: 18ch;
      margin-top: var(--space-3);
      letter-spacing: var(--tracking-tight);
    }
    .nsb-home__summary {
      font-size: var(--text-lg);
      color: var(--color-ink-dim);
      max-width: var(--reading-max);
    }

    /* category map */
    .nsb-home__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: 0;
      border-top: var(--rule);
      border-left: var(--rule);
      margin-bottom: var(--space-8);
    }
    .nsb-home__card {
      display: block;
      padding: var(--space-6);
      border-right: var(--rule);
      border-bottom: var(--rule);
      text-decoration: none;
      color: inherit;
      background: var(--color-surface);
      transition: background var(--dur-fast) var(--ease);
    }
    .nsb-home__card:hover { background: var(--color-paper-alt); }
    .nsb-home__card-title {
      font-size: var(--text-xl);
      margin-top: var(--space-3);
      margin-bottom: var(--space-3);
      font-family: var(--font-sans);
      font-weight: 600;
      letter-spacing: var(--tracking-tight);
    }
    .nsb-home__card-summary {
      font-family: var(--font-serif);
      color: var(--color-ink-dim);
      margin-bottom: var(--space-4);
      font-size: var(--text-base);
      line-height: var(--leading-snug);
    }
    .nsb-home__card-count {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: lowercase;
      color: var(--color-ink-faint);
      margin: 0;
    }

    /* FM preview strip */
    .nsb-home__preview {
      margin-bottom: var(--space-8);
    }
    .nsb-home__preview-header {
      padding-bottom: var(--space-5);
      border-bottom: var(--rule);
      margin-bottom: var(--space-5);
    }
    .nsb-home__preview-title {
      font-size: var(--text-2xl);
      margin: var(--space-2) 0 var(--space-3) 0;
      letter-spacing: var(--tracking-tight);
    }
    .nsb-home__preview-note {
      font-family: var(--font-serif);
      color: var(--color-ink-dim);
      font-size: var(--text-md);
      line-height: var(--leading-relaxed);
      max-width: var(--reading-max);
      margin: 0;
    }
    .nsb-home__preview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
      gap: 0;
      border-top: var(--rule);
      border-left: var(--rule);
    }
    .nsb-home__preview-more {
      margin: var(--space-5) 0 0 0;
      font-family: var(--font-sans);
      font-size: var(--text-sm);
    }
    .nsb-home__preview-link {
      color: var(--accent-current);
      text-decoration: none;
    }
    .nsb-home__preview-link:hover {
      text-decoration: underline;
      text-decoration-color: var(--accent-current);
    }

    /* status aside */
    .nsb-home__status {
      border-top: var(--rule);
      padding-top: var(--space-5);
      margin-top: var(--space-6);
    }
    .nsb-home__status-text {
      font-family: var(--font-serif);
      font-size: var(--text-base);
      color: var(--color-ink-soft);
      max-width: var(--reading-max);
      margin: var(--space-2) 0 0 0;
      line-height: var(--leading-snug);
    }
  </style>
</BaseLayout>
