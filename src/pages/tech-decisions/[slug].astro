---
/**
 * Tech Decisions detail page.
 *
 * Eight-section structure, arranged as a decision-support manual:
 *
 *   01  THE DECISION          — question, summary, heuristic
 *   02  WHAT IT'S REALLY ABOUT — reframes (what it is NOT about; why it feels hard)
 *   03  OPTIONS ON THE TABLE  — structured A/B options via OptionsLedger
 *   04  COST AND TIME         — costBearer + timeHorizonNotes structured pairs
 *   05  HOW TO DECIDE         — key factors, questions, evidence, default bias,
 *                               reversibility, when to revisit
 *   06  SIGNALS FROM THE GROUND — common bad reasons, anti-patterns, good signals
 *   07  AI IMPACT             — aiCanHelpWith / aiCanMakeWorseBy / aiSpecificNotes
 *   08  CONNECTED DECISIONS   — cross-category cross-references
 *
 * Section visibility is driven by whether the underlying fields carry content,
 * same policy as the FM detail page — never render an empty section or an
 * orphaned anchor in the SectionIndex.
 *
 * Reuses the shared primitives: DetailLayout, SectionHeader, SectionIndex (with
 * its scroll-spy), MetaRail, RelatedEntries, Tag, CalloutBand, LabeledList
 * (new for TD but shared), OptionsLedger (new for TD, shared).
 * FM-specific primitives (WarningSignsByStage, OperatorNotes as wired for FM,
 * HeardInTheWild) are deliberately not used here — those are category-specific
 * narrative components, not a universal detail-page chassis.
 */

import DetailLayout from "@/layouts/DetailLayout.astro";
import AtAGlance from "@/components/AtAGlance.astro";
import CalloutBand from "@/components/CalloutBand.astro";
import LabeledList from "@/components/LabeledList.astro";
import MetaRail from "@/components/MetaRail.astro";
import OptionsLedger from "@/components/OptionsLedger.astro";
import RelatedEntries from "@/components/RelatedEntries.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import SectionIndex from "@/components/SectionIndex.astro";
import Tag from "@/components/Tag.astro";
import { loadTechDecisions } from "@/lib/load";
import { formatRefCode, resolveSlug } from "@/lib/resolve";
import { ensureValidated } from "@/lib/validate";
import type { TechDecisionEntry } from "@/content/schemas/tech-decision";
import {
  SEVERITY_SCALE,
  FREQUENCY_SCALE,
  REVERSIBILITY_SCALE,
  CONFIDENCE_SCALE,
  barCounts,
  isFrequencyTrend,
  isReversibilityLevel,
  severityTagVariant,
} from "@/lib/attribute-scales";

export async function getStaticPaths() {
  ensureValidated();
  return loadTechDecisions().entries.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const allTd = loadTechDecisions().entries;
const entry: TechDecisionEntry | undefined = allTd.find((e) => e.slug === slug);
if (!entry) {
  throw new Error(`Tech Decision not found for slug "${slug}"`);
}

// Section visibility — each evaluated against the real content of this
// entry. Section numbering recomputes positionally so a skipped AI block
// (say) doesn't leave a gap in the `01 · 02 · 03…` sequence.
// Note: whatThisIsReallyAbout / notActuallyAbout / whyItFeelsHard used
// to drive a dedicated "sec-framing" section below sec-decision. They
// are now surfaced at the top of the page via the shared AtAGlance
// panel (blue-fill identity strip), so sec-framing has been retired
// entirely and the section numbering collapses accordingly.
// Cost / time / reversibility — combined section now holds three editorial
// panels: who pays (costBearer), when each option wins over time
// (timeHorizonNotes), and how hard it is to undo + what should force a
// re-look (reversibility + whenToRevisit). Reversibility and whenToRevisit
// used to live in "How to decide" but they're time-sensitivity content,
// not decision-support content. Moving them here tightens the editorial
// story of each section.
const hasReversibilityPanel = Boolean(
  entry.reversibility ||
  (entry.whenToRevisit && entry.whenToRevisit.length > 0),
);
const hasCostTime = Boolean(
  entry.costBearer || entry.timeHorizonNotes || hasReversibilityPanel,
);
const hasSignals = Boolean(
  (entry.commonBadReasons && entry.commonBadReasons.length > 0) ||
  (entry.antiPatterns && entry.antiPatterns.length > 0) ||
  (entry.goodSignalsForA && entry.goodSignalsForA.length > 0) ||
  (entry.goodSignalsForB && entry.goodSignalsForB.length > 0),
);
const hasAiBlock = Boolean(
  (entry.aiCanHelpWith && entry.aiCanHelpWith.length > 0) ||
  (entry.aiCanMakeWorseBy && entry.aiCanMakeWorseBy.length > 0) ||
  entry.aiFalseConfidence ||
  entry.aiSpecificNotes,
);
const hasEasilyConfused = Boolean(
  entry.easilyConfusedWith && entry.easilyConfusedWith.length > 0,
);
const hasRelationships = Boolean(
  hasEasilyConfused ||
  (entry.oftenLeadsToFailureModes && entry.oftenLeadsToFailureModes.length > 0) ||
  (entry.adjacentDecisions && entry.adjacentDecisions.length > 0) ||
  (entry.relatedRedFlags && entry.relatedRedFlags.length > 0) ||
  (entry.relatedPlaybooks && entry.relatedPlaybooks.length > 0),
);

// Secondary panels inside "How to decide" only render when the content
// exists. `questionsToAsk` is required by the schema, so the primary
// panel always renders; `keyFactors` and `evidenceNeeded` are optional
// but universally populated in the current content set.
const hasDecisionSupport = Boolean(
  (entry.keyFactors && entry.keyFactors.length > 0) ||
  (entry.evidenceNeeded && entry.evidenceNeeded.length > 0),
);

// Diagnostic halves of the Signals section — split left (what's usually
// pushing the call, i.e. the wrong pressures) from right (what should
// push the call, i.e. the real signals). Each half renders only if it
// has at least one populated sub-field, so a sparse entry can degrade
// gracefully without orphaning a masthead.
const hasBadPressureHalf = Boolean(
  (entry.commonBadReasons && entry.commonBadReasons.length > 0) ||
  (entry.antiPatterns && entry.antiPatterns.length > 0),
);
const hasGoodSignalsHalf = Boolean(
  (entry.goodSignalsForA && entry.goodSignalsForA.length > 0) ||
  (entry.goodSignalsForB && entry.goodSignalsForB.length > 0),
);

/**
 * `capFirst` — force a leading capital on body-prose strings rendered on
 * this page. Several TD fields are authored mid-sentence (`defaultBias`,
 * `timeHorizonNotes.optionA/B`, `aiSpecificNotes`, etc.) because they
 * conceptually continue the section's lead-in. But on the page they
 * render as standalone sentences, so inconsistent casing reads as a
 * bug. Identical in shape to the FM page's `capFirst`; kept local to
 * this page so other categories render as authored.
 *
 * Idempotent — already-capitalized strings pass through unchanged. We
 * only apply it at serif/sans body-text render points; AtAGlance,
 * MetaRail, and eyebrows already force uppercase via CSS and so don't
 * need this helper.
 */
function capFirst(s: string | undefined | null): string {
  if (typeof s !== "string") return "";
  const trimmed = s.trimStart();
  if (trimmed.length === 0) return "";
  return trimmed[0].toUpperCase() + trimmed.slice(1);
}
function capItems(items: readonly string[] | undefined | null): string[] {
  if (!Array.isArray(items)) return [];
  return items.map((s) => capFirst(s));
}

// Resolve each `easilyConfusedWith[].decision` eagerly at build time. The
// `decision` field is intentionally polymorphic: either a TD slug
// (renders with a `TD-XX · Title` link) or a short human phrase for a
// nearby decision that isn't itself an entry (renders with an "Adjacent
// concept" eyebrow). Mirrors the FM `easilyConfusedWith` pattern so
// readers recognize the two visual modes across categories.
const easilyConfusedResolved = (entry.easilyConfusedWith ?? []).map((item) => ({
  raw: item.decision,
  distinction: item.distinction,
  ref: resolveSlug(item.decision),
}));

// Catalog reference code — shared helper so the masthead pill and every
// incoming cross-reference stay in lockstep.
const indexInFile = allTd.findIndex((e) => e.slug === entry.slug);
const { refCode } = formatRefCode("TD", indexInFile, allTd.length);

// Severity-if-wrong pill variant on the masthead. Uses the shared
// `severityTagVariant` helper so a reader seeing a "high severity"
// weight on an FM card and a "severityIfWrong: high" pill on a TD
// card reads them as equivalent gravity, not as two unrelated scales.
const severityPillVariant = entry.severityIfWrong
  ? severityTagVariant(entry.severityIfWrong)
  : undefined;

// Prettify subcategory slug for display. Kept simple — no i18n needed
// because the subcategory values are site-canonical english words.
const prettifySub = (s: string): string =>
  s.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");

const sectionSpecs: Array<{ id: string; label: string; shown: boolean }> = [
  { id: "sec-decision",      label: "The decision",             shown: true },
  { id: "sec-options",       label: "Options on the table",     shown: true },
  { id: "sec-cost-time",     label: "Cost and time",            shown: hasCostTime },
  { id: "sec-how-to-decide", label: "How to decide",            shown: true },
  { id: "sec-signals",       label: "Signals from the ground",  shown: hasSignals },
  { id: "sec-ai",            label: "AI impact",                shown: hasAiBlock },
  { id: "sec-relationships", label: "Connected decisions",      shown: hasRelationships },
];
const sections = sectionSpecs
  .filter((s) => s.shown)
  .map((s, i) => ({ step: String(i + 1).padStart(2, "0"), id: s.id, label: s.label }));
const stepFor = (id: string) => sections.find((s) => s.id === id)?.step ?? "";
---

<DetailLayout
  code="TD"
  title={entry.title}
  summary={entry.summary}
  subcategory={prettifySub(entry.category)}
  refCode={refCode}
>
  {/* Masthead pill row — severity-if-wrong carries the ramp color,
      frequency rendered plain. Reversibility is intentionally NOT
      repeated here because the MetaRail below carries it as a first-
      class dimension with its own bar ladder; a second pill would be
      redundant signal. Severity stays pilled because its color is a
      category-wide gravity cue that also links visually back to the
      landing-grid card fills. */}
  <Fragment slot="header-stamp">
    {entry.severityIfWrong && severityPillVariant && (
      <Tag label={`Severity if wrong · ${entry.severityIfWrong}`} variant={severityPillVariant} size="sm" />
    )}
    {entry.frequency && <Tag label={`Freq · ${entry.frequency}`} variant="outline" size="sm" />}
  </Fragment>

  <Fragment slot="nav-rail">
    <SectionIndex items={sections} eyebrow="In this decision" />
  </Fragment>

  {/* Snapshot metadata rail — cell order mirrors the FM detail MetaRail
      so readers get the same left-to-right reading rhythm across
      categories:

        FM  ·  Severity   → Frequency → Lifecycle → Recovery       → Confidence
        TD  ·  Sev if wrong → Frequency → Audiences → Reversibility → Confidence

      The semantic mapping is deliberate: Lifecycle (FM list-of-stages)
      corresponds to Audiences (TD list-of-roles) — both are bar-less
      "who/when" lists. Recovery (FM ladder) corresponds to Reversibility
      (TD ladder) — both answer "how hard to undo once you're in it".

      Reversibility uses its own five-step scale. Most entries land on
      one of the five canonical tokens; a handful carry nuanced values
      ("depends on surface", etc.). For those off-scale values we drop
      the bar ladder and just render the string — see
      `isReversibilityLevel`. */}
  <MetaRail
    items={[
      ...(entry.severityIfWrong ? [{
        label: "Severity if wrong",
        value: entry.severityIfWrong,
        severity: entry.severityIfWrong,
        scale: barCounts(SEVERITY_SCALE, entry.severityIfWrong),
      }] : []),
      ...(entry.frequency ? [{
        label: "Frequency",
        value: entry.frequency,
        ...(isFrequencyTrend(entry.frequency)
          ? { trend: "increasing" as const }
          : { scale: barCounts(FREQUENCY_SCALE, entry.frequency) }),
      }] : []),
      ...(entry.audiences && entry.audiences.length > 0 ? [{
        label: "Audiences",
        value: entry.audiences,
      }] : []),
      ...(entry.reversibility ? [{
        label: "Reversibility",
        value: entry.reversibility,
        ...(isReversibilityLevel(entry.reversibility)
          ? { scale: barCounts(REVERSIBILITY_SCALE, entry.reversibility) }
          : {}),
      }] : []),
      {
        label: "Confidence",
        value: entry.patternConfidence,
        scale: barCounts(CONFIDENCE_SCALE, entry.patternConfidence),
      },
    ]}
  />

  {/* AT A GLANCE — shared blue-fill identity panel. TD's orienting fields
      (what this is really about / what it isn't / why it feels hard /
      who the call belongs to) used to live as a "Beneath the surface"
      body section further down the page. Promoting them up here — into
      the same blue at-a-glance ritual FM uses — lets a reader calibrate
      what the decision IS before reading "The decision" question below,
      and removes a whole body section whose content was really identity
      metadata masquerading as prose. Section 2 in the old numbering is
      gone; sec-decision is now section 1. */}
  <AtAGlance
    refCode={refCode}
    rows={[
      { label: "Really about",       value: entry.whatThisIsReallyAbout },
      /* `negate` flips this cell to the black-fill / yellow-label
         inverse treatment — preserves the deliberate "negation" hit
         the old td-framing__row--negative treatment carried before
         the AtAGlance migration. No other page uses this flag today. */
      { label: "Not actually about", value: entry.notActuallyAbout, negate: true },
      { label: "Why it feels hard", value: entry.whyItFeelsHard },
      /* Audiences intentionally OMITTED from AtAGlance — it is already
         carried as a first-class dimension on the MetaRail above (the
         "Audiences" cell). Duplicating it here would dilute the panel's
         identity-framing purpose. Three cells is also a cleaner 3-col
         grid at ≥640px than four. */
    ]}
  />

  {/* 1. THE DECISION — the whole reason this page exists. `decisionQuestion`
        is REQUIRED in the TD schema; it deserves to read as the opening
        editorial beat, not as a dt/dd buried in the metadata.
        
        This section now carries three stance beats for opening framing:
          1. `summary`           — what we're looking at in one sentence
          2. `decisionHeuristic` — the editorial rule-of-thumb (yellow band)
          3. `defaultBias`       — where a reader should start before
                                   gathering evidence (framed "default stance"
                                   block; promoted up from section 5)
        
        `defaultBias` used to render as a small inline label+body line
        inside "How to decide", which treated it as decision-support
        detail. It is actually framing — the starting stance a reader
        inherits before they've gathered anything. Promoting it into
        the opening makes the page's default position legible in the
        first screenful, the same way `mistakenFor` / `oftenMistakenAs`
        anchor FM recognition at the top of each FM page. */}
  <SectionHeader
    id="sec-decision"
    step={stepFor("sec-decision")}
    eyebrow="The decision"
    title={entry.decisionQuestion}
  />
  <div class="td-prose td-decision__body">
    <p>{capFirst(entry.summary)}</p>
    {entry.decisionHeuristic && (
      <CalloutBand label="Heuristic" variant="yellow" serif>
        <p>{capFirst(entry.decisionHeuristic)}</p>
      </CalloutBand>
    )}
    {entry.defaultBias && (
      <section class="td-stance" aria-label="Default stance">
        <p class="td-stance__label">Default stance</p>
        <p class="td-stance__caption">Where to start before any evidence arrives.</p>
        <p class="td-stance__body">{capFirst(entry.defaultBias)}</p>
      </section>
    )}
  </div>

  {/* 3. OPTIONS ON THE TABLE — the site's signature TD visual. */}
  <SectionHeader
    id="sec-options"
    step={stepFor("sec-options")}
    eyebrow="Options on the table"
    title="Two poles of the trade-off"
    note="Neither is the right answer by default. Each option's conditions, strengths, costs, hidden costs, and failure modes when misused are laid out in parallel so you can read across facets."
  />
  <OptionsLedger optionA={entry.optionA} optionB={entry.optionB} />

  {/* 4. COST, TIME, AND REVERSIBILITY — three editorial panels that each
        answer a different sharp question:
          · `costBearer`       — WHO pays the cost of this decision
          · `timeHorizonNotes` — HOW the right answer shifts over time
          · `reversibility` + `whenToRevisit`
                               — WHAT undoing this decision costs and
                                 WHICH signals should force a re-look

        Reversibility + whenToRevisit used to live inside "How to decide"
        as two separate mini-rows; they're actually time-sensitivity
        content ("how the right answer changes over time"), not
        decision-support. Moving them here turns the section into a
        single honest account of the decision's temporal shape — who
        carries it, how it ages, and how costly it is to undo. */}
  {hasCostTime && (
    <>
      <SectionHeader
        id="sec-cost-time"
        step={stepFor("sec-cost-time")}
        eyebrow="Cost, time, and reversibility"
        title="Who pays, how it ages, and what undoing it costs"
        note="Trade-offs are rarely zero-sum and rarely static. Someone pays, the payoff curve shifts with the horizon, and the decision has an undo cost."
      />
      <div class="td-pairs">
        {entry.costBearer && (
          <section class="td-pair" aria-label="Cost bearer">
            <header class="td-pair__head">Cost bearer</header>
            <div class="td-pair__grid">
              <div class="td-pair__col">
                <p class="td-pair__col-head">Option A · {entry.optionA.name}</p>
                <LabeledList label="Who absorbs the cost" items={capItems(entry.costBearer.optionA)} dense />
              </div>
              <div class="td-pair__col">
                <p class="td-pair__col-head">Option B · {entry.optionB.name}</p>
                <LabeledList label="Who absorbs the cost" items={capItems(entry.costBearer.optionB)} dense />
              </div>
            </div>
          </section>
        )}
        {entry.timeHorizonNotes && (
          <section class="td-pair" aria-label="Time horizon">
            <header class="td-pair__head">Time horizon</header>
            <div class="td-pair__grid">
              <div class="td-pair__col">
                <p class="td-pair__col-head">Option A · {entry.optionA.name}</p>
                <p class="td-pair__col-body">{capFirst(entry.timeHorizonNotes.optionA)}</p>
              </div>
              <div class="td-pair__col">
                <p class="td-pair__col-head">Option B · {entry.optionB.name}</p>
                <p class="td-pair__col-body">{capFirst(entry.timeHorizonNotes.optionB)}</p>
              </div>
            </div>
          </section>
        )}
        {/* Reversibility + whenToRevisit panel — same framed anatomy as
            the two A/B panels above, but the body is a single column
            rather than a two-column A/B split because reversibility
            and revisit triggers apply to the decision as a whole, not
            to each option independently. The two bodies stack as
            "What undoing costs" (reversibility) and "What should force
            a re-look" (whenToRevisit). The whole panel renders only
            when at least one of the two fields has content. */}
        {hasReversibilityPanel && (
          <section class="td-pair td-pair--wide" aria-label="Reversibility">
            <header class="td-pair__head">Reversibility</header>
            <div class="td-pair__single">
              {entry.reversibility && (
                <div class="td-pair__block">
                  <p class="td-pair__col-head">What undoing costs</p>
                  <p class="td-pair__col-body">{capFirst(entry.reversibility)}</p>
                </div>
              )}
              {entry.whenToRevisit && entry.whenToRevisit.length > 0 && (
                <div class="td-pair__block">
                  <LabeledList
                    label="What should force a re-look"
                    items={capItems(entry.whenToRevisit)}
                    caption="Trigger conditions that mean the answer may have changed."
                    dense
                  />
                </div>
              )}
            </div>
          </section>
        )}
      </div>
    </>
  )}

  {/* 5. HOW TO DECIDE — decision support.
        
        Restructured for clearer hierarchy: `questionsToAsk` is the
        editorial primary block (boxed, yellow-headed masthead) because
        answering those questions is, literally, most of the decision.
        `keyFactors` and `evidenceNeeded` are the working material you
        need to answer them — rendered as a two-column secondary row
        below the primary panel.
        
        `defaultBias` used to live here as an inline label+body row;
        it has been promoted up to the "The decision" section as a
        framed stance block. `reversibility` and `whenToRevisit` used
        to live here too; they've moved down into "Cost, time, and
        reversibility" where they belong editorially. What's left is
        the sharpest possible decision-support block: the questions,
        the variables, and the evidence. */}
  <SectionHeader
    id="sec-how-to-decide"
    step={stepFor("sec-how-to-decide")}
    eyebrow="How to decide"
    title="The work you still have to do"
    note="The reference can frame the trade-off; only you can weight the factors against your context."
  />
  <div class="td-decide">
    <LabeledList
      variant="boxed"
      label="Questions to ask"
      items={capItems(entry.questionsToAsk)}
      caption="Open these in the room. Answering them is most of the decision."
    />
    {hasDecisionSupport && (
      <div class="td-decide__support">
        {entry.keyFactors && entry.keyFactors.length > 0 && (
          <LabeledList
            variant="framed"
            label="Key factors"
            items={capItems(entry.keyFactors)}
            caption="The variables that actually move the answer."
          />
        )}
        {entry.evidenceNeeded && entry.evidenceNeeded.length > 0 && (
          <LabeledList
            variant="framed"
            label="Evidence needed"
            items={capItems(entry.evidenceNeeded)}
            caption="What to gather before committing — not after."
          />
        )}
      </div>
    )}
  </div>

  {/* 6. SIGNALS FROM THE GROUND — diagnostic evidence from real teams.
        
        Split into two editorial halves side by side, not a flat stack:
        
          · LEFT  (td-signals__bad)  — "What's usually pushing the call"
            holds `commonBadReasons` + `antiPatterns`. These are the
            wrong pressures the reader should recognize and set aside.
            Red-framed panel, parallels the red band treatment used for
            hazard content elsewhere on the site.
        
          · RIGHT (td-signals__good) — "What should push the call"
            holds `goodSignalsForA` + `goodSignalsForB`. Concrete
            observations that genuinely point to one pole or the other.
            Surface-framed panel, neutral treatment.
        
        Each half has its own masthead eyebrow so a reader scanning the
        section can immediately see the split between "pressures to
        discount" and "signals to trust". Each LabeledList inside a
        half renders only when its source field has content, and the
        whole half renders only when at least one of its two fields
        has content — matches the "render nothing when empty" policy
        used elsewhere on the page. */}
  {hasSignals && (
    <>
      <SectionHeader
        id="sec-signals"
        step={stepFor("sec-signals")}
        eyebrow="Signals from the ground"
        title="What's usually pushing the call, and what should"
        note="On the left, pressures to recognize and discount. On the right, signals that genuinely point toward one option or the other."
      />
      <div class="td-signals-split">
        {hasBadPressureHalf && (
          <section class="td-signals-half td-signals-half--bad" aria-label="What's usually pushing the call">
            <header class="td-signals-half__head">
              <p class="td-signals-half__eyebrow">What's usually pushing the call</p>
              <p class="td-signals-half__caption">Pressures to recognize and discount.</p>
            </header>
            <div class="td-signals-half__body">
              {entry.commonBadReasons && entry.commonBadReasons.length > 0 && (
                <LabeledList
                  label="Common bad reasons"
                  items={capItems(entry.commonBadReasons)}
                  caption="Reasoning that feels convincing in the moment but doesn't hold up."
                />
              )}
              {entry.antiPatterns && entry.antiPatterns.length > 0 && (
                <LabeledList
                  label="Anti-patterns"
                  items={capItems(entry.antiPatterns)}
                  caption="Shapes of reasoning to recognize and set aside."
                />
              )}
            </div>
          </section>
        )}
        {hasGoodSignalsHalf && (
          <section class="td-signals-half td-signals-half--good" aria-label="What should push the call">
            <header class="td-signals-half__head">
              <p class="td-signals-half__eyebrow">What should push the call</p>
              <p class="td-signals-half__caption">Concrete signals that genuinely point to one pole.</p>
            </header>
            <div class="td-signals-half__body">
              {entry.goodSignalsForA && entry.goodSignalsForA.length > 0 && (
                <LabeledList
                  label={`For · ${entry.optionA.name}`}
                  items={capItems(entry.goodSignalsForA)}
                  caption="Observations that genuinely point to Option A."
                />
              )}
              {entry.goodSignalsForB && entry.goodSignalsForB.length > 0 && (
                <LabeledList
                  label={`For · ${entry.optionB.name}`}
                  items={capItems(entry.goodSignalsForB)}
                  caption="Observations that genuinely point to Option B."
                />
              )}
            </div>
          </section>
        )}
      </div>
    </>
  )}

  {/* 7. AI IMPACT — same treatment as FM's AI block: positive leverage +
        negative distortion + a standalone synthesis note if present. */}
  {hasAiBlock && (
    <>
      <SectionHeader
        id="sec-ai"
        step={stepFor("sec-ai")}
        eyebrow="AI impact"
        title="How AI bends this decision"
        note="Where AI accelerates the call, where it introduces new distortions, and anything else worth knowing."
      />
      {/* AI section — unified site-wide treatment: two boxed
          LabeledLists side-by-side with equal row heights + blue-
          serif synthesis band below. Matches FM / RF / EP (see
          docs/launch-readiness.md §1). The synthesis band
          deliberately lives OUTSIDE the two-col grid so it spans
          full width. `--equal` aligns bottom edges when one list
          is longer than the other. */}
      <div class="nsb-two-col nsb-two-col--equal">
        <LabeledList
          variant="boxed"
          label="AI can help with"
          items={capItems(entry.aiCanHelpWith)}
          caption="Where AI genuinely reduces the cost of making the call."
        />
        <LabeledList
          variant="boxed"
          label="AI can make worse"
          items={capItems(entry.aiCanMakeWorseBy)}
          caption="Distortions AI introduces that didn't exist before."
        />
      </div>
      {entry.aiFalseConfidence && (
        /* Pattern-specific false-confidence warning — the specific
           illusion of correctness, coverage, or progress AI produces
           in the shape of THIS decision. Red variant so it reads as
           a warning distinct from the blue synthesis below (which
           carries the editorial takeaway). Parallels the same field
           on the FM detail page so readers recognize the treatment. */
        <CalloutBand label="AI false confidence" variant="red">
          <p>{capFirst(entry.aiFalseConfidence)}</p>
        </CalloutBand>
      )}
      {entry.aiSpecificNotes && (
        <CalloutBand label="AI synthesis" variant="blue" serif>
          <p>{capFirst(entry.aiSpecificNotes)}</p>
        </CalloutBand>
      )}
    </>
  )}

  {/* 8. CONNECTED DECISIONS AND PATTERNS — directional cross-references. */}
  {hasRelationships && (
    <>
      <SectionHeader
        id="sec-relationships"
        step={stepFor("sec-relationships")}
        eyebrow="Relationships"
        title="Connected decisions"
        note="Nearby decisions this is sometimes confused with, adjacent decisions that are often entangled with this one, related failure modes, red flags, and playbooks to reach for."
      />

      {/* "Easy to confuse with" — recognition-boundary panel. Distinct
          from `adjacentDecisions` (neutral neighborhood grid below) and
          from `notActuallyAbout` (a single-sentence framing negation up
          top). This block is specifically about disambiguation: sibling
          decisions + one-line distinctions explaining how THIS decision
          differs. Rendered at the TOP of the Relationships section so a
          reader who still isn't sure "am I making the right decision?"
          reaches this before the cross-reference grid.

          When a `decision` resolves to a real TD slug, the cell links to
          that detail page and shows its refCode pill; free-phrase
          decisions render with an "Adjacent concept" eyebrow. Mirrors the
          FM `easilyConfusedWith` panel so the two categories read as one
          design pattern in two modes. */}
      {hasEasilyConfused && (
        <section class="td-confused" aria-label="Easy to confuse with">
          <header class="td-confused__head">
            <h3 class="td-confused__title">Easy to confuse with</h3>
            <p class="td-confused__note">
              Nearby decisions and how this one differs.
            </p>
          </header>
          <ul class="td-confused__list">
            {easilyConfusedResolved.map((item) => (
              <li class="td-confused__item">
                <div class="td-confused__pattern">
                  {item.ref ? (
                    <a class="td-confused__link" href={item.ref.href}>
                      <span class="td-confused__ref">{item.ref.refCode}</span>
                      <span class="td-confused__name">{item.ref.title}</span>
                    </a>
                  ) : (
                    <span class="td-confused__concept">
                      <span class="td-confused__concept-eyebrow">Adjacent concept</span>
                      <span class="td-confused__phrase">{capFirst(item.raw)}</span>
                    </span>
                  )}
                </div>
                <p class="td-confused__distinction">{capFirst(item.distinction)}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <div class="nsb-two-col nsb-two-col--equal">
        <RelatedEntries
          eyebrow="Often leads to failure modes"
          title="Often leads to failure modes"
          refs={entry.oftenLeadsToFailureModes}
          expectCategory="FM"
          dense
        />
        <RelatedEntries
          eyebrow="Adjacent decisions"
          title="Adjacent decisions"
          refs={entry.adjacentDecisions}
          expectCategory="TD"
          dense
        />
        <RelatedEntries
          eyebrow="Related red flags"
          title="Related red flags"
          refs={entry.relatedRedFlags}
          expectCategory="RF"
          dense
        />
        <RelatedEntries
          eyebrow="Related playbooks"
          title="Related playbooks"
          refs={entry.relatedPlaybooks}
          expectCategory="EP"
          dense
        />
      </div>
    </>
  )}
</DetailLayout>

<style>
  /* ---- Prose body text (sections 1, 2 intros, AI note body) ------ */
  .td-prose {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-ink);
    margin: var(--space-4) 0 0 0;
    text-wrap: pretty;
    max-width: none;
  }
  .td-prose p { margin: 0 0 var(--space-4) 0; }
  .td-prose p:last-child { margin-bottom: 0; }

  .td-decision__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ---- Default stance — framed stance block rendered inside the
     "The decision" section, under the yellow `decisionHeuristic`
     band. Carries `defaultBias` (the reader's starting position
     before any evidence is gathered). White surface + 3px black
     frame + black eyebrow strip, parallel in weight to the yellow
     CalloutBand above it so the two stance beats read as a pair
     (heuristic = editorial rule of thumb / default stance = where
     to start). Not a CalloutBand itself because we want a sharper
     two-line editorial register here (label + caption + body),
     which the CalloutBand primitive doesn't model. */
  .td-stance {
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
    padding: var(--space-4) var(--space-5);
  }
  .td-stance__label {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .td-stance__caption {
    margin: 2px 0 var(--space-3) 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    line-height: var(--leading-snug);
    color: var(--color-ink-soft);
  }
  .td-stance__body {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }

  /* The legacy `.td-framing*` styles are gone — the three reframe
     fields (whatThisIsReallyAbout / notActuallyAbout / whyItFeelsHard)
     now render inside the shared AtAGlance blue panel at the top of
     the page and carry no TD-local styling. */

  /* ---- Cost / time pair panels. Two small framed panels in a row
        at desktop, stacked on narrow. Each panel has a black masthead
        and a 2-col body (option A | option B). */
  .td-pairs {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 960px) {
    .td-pairs { grid-template-columns: 1fr 1fr; }
  }
  .td-pair {
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
    display: flex;
    flex-direction: column;
  }
  .td-pair__head {
    padding: var(--space-3) var(--space-4);
    background: var(--color-frame);
    color: var(--color-yellow);
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  /* Sub-grid for Option A / Option B inside a pair panel. Narrow keeps
     the flex stack; wide uses CSS subgrid so the "Option A · Name"
     label row and the body row line up horizontally between the two
     columns — otherwise a long option name like "STANDARDIZATION"
     wrapping to 2 lines pushes the body down on its side only, and
     the two bodies start at different Y-offsets. */
  .td-pair__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 540px) {
    .td-pair__grid {
      grid-template-columns: 1fr 1fr;
      /* Row 1 = option-head labels (aligned), row 2 = bodies. */
      grid-template-rows: auto 1fr;
      row-gap: 0;
    }
    .td-pair__col + .td-pair__col {
      border-left: 2px solid var(--color-frame);
    }
  }
  @media (max-width: 539px) {
    .td-pair__col + .td-pair__col {
      border-top: 2px solid var(--color-frame);
    }
  }
  /* Narrow-width col: flex stack. */
  .td-pair__col {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }
  @media (min-width: 540px) {
    /* Wide-width col: subgrid spanning the 2 pair rows so the head
       label and the body align horizontally across columns. */
    .td-pair__col {
      display: grid;
      grid-template-rows: subgrid;
      grid-row: 1 / span 2;
      row-gap: var(--space-3);
    }
  }
  .td-pair__col-head {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .td-pair__col-body {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }

  /* Wide-pair variant — the reversibility panel spans both columns at
     desktop because reversibility and revisit triggers apply to the
     decision as a whole, not to each option independently. At narrow
     widths the regular single-column stack handles it. Its body uses
     `.td-pair__single` (NOT the A/B grid) with two stacked blocks:
     "What undoing costs" + "What should force a re-look". */
  @media (min-width: 960px) {
    .td-pair--wide { grid-column: 1 / -1; }
  }
  .td-pair__single {
    padding: var(--space-4) var(--space-5);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 540px) {
    /* Two blocks sit side by side on desktop only if BOTH are populated;
       the grid uses `auto-fit` with a min track so a single populated
       block fills the row cleanly. No A/B subgrid here because the two
       blocks are semantically distinct (not two views of the same
       attribute), so alignment-across-blocks isn't required. */
    .td-pair__single {
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: var(--space-5);
    }
  }
  .td-pair__block { min-width: 0; }
  .td-pair__block .td-pair__col-head {
    margin-bottom: var(--space-2);
  }

  /* ---- 5. How to decide — primary+secondary layout.
        
        `questionsToAsk` renders as a full-width boxed LabeledList (the
        primary block — answering those questions is most of the
        decision). Below it, the `.td-decide__support` row holds
        `keyFactors` and `evidenceNeeded` as two framed panels side by
        side (the working material needed to answer the questions).
        
        No more inline label+body rows — `defaultBias` has moved up to
        the opening "The decision" section, and `reversibility` /
        `whenToRevisit` have moved down to "Cost, time, and
        reversibility". The resulting block is deliberately sparser:
        it carries only the three items that are, strictly, decision
        support. */
  .td-decide {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .td-decide__support {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 720px) {
    .td-decide__support {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
  }

  /* ---- 6. Signals from the ground — two editorial halves.
        
        Two side-by-side panels, each with its own masthead eyebrow
        (the "What's usually pushing the call" vs "What should push
        the call" framing the user asked for). The bad-pressure half
        uses a red masthead strip because its content is "pressures
        to discount"; the good-signals half uses the surface frame
        because its content is neutral reference signal. Both halves
        contain one or two LabeledLists, separated by a thin rule.
        
        At narrow widths the two halves stack. Each half renders only
        when at least one of its source fields is populated. */
  .td-signals-split {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 860px) {
    .td-signals-split {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
  }
  .td-signals-half {
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .td-signals-half__head {
    padding: var(--space-3) var(--space-4);
    border-bottom: 3px solid var(--color-frame);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .td-signals-half--bad .td-signals-half__head {
    background: var(--color-red);
    color: var(--color-surface);
  }
  .td-signals-half--good .td-signals-half__head {
    background: var(--color-frame);
    color: var(--color-surface);
  }
  .td-signals-half__eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-yellow);
  }
  .td-signals-half--bad .td-signals-half__eyebrow {
    color: var(--color-yellow);
  }
  .td-signals-half__caption {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.78rem;
    line-height: var(--leading-snug);
    color: rgba(255, 255, 255, 0.78);
  }
  .td-signals-half__body {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .td-signals-half__body > * + * {
    padding-top: var(--space-4);
    border-top: 1.5px solid var(--color-rule);
  }

  /* ---- 7. AI impact — uses the shared site-wide treatment now
     (two boxed LabeledLists via `.nsb-two-col` + red false-confidence
     band + blue-serif synthesis CalloutBand). No TD-specific styling. */

  /* ---- 8. "Easy to confuse with" panel + Relationships grid.

     The confused panel parallels the FM `.fm-confused` block — same
     anatomy (black eyebrow bar + linked pill | italic phrase + serif
     distinction) so a reader recognizes the pattern across categories.
     Class namespace is `.td-confused` rather than sharing `.fm-*` so
     each category can tune its typography separately if needed
     without changes on one side leaking into the other. */
  .td-confused {
    margin-top: var(--space-5);
    border: 3px solid var(--color-frame);
    background: var(--color-surface);
  }
  .td-confused__head {
    padding: var(--space-3) var(--space-4);
    background: var(--color-frame);
    color: var(--color-surface);
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .td-confused__title {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-yellow);
  }
  .td-confused__note {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.78rem;
    line-height: var(--leading-snug);
    color: rgba(255, 255, 255, 0.7);
  }
  .td-confused__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .td-confused__item {
    display: grid;
    grid-template-columns: minmax(12rem, 16rem) 1fr;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-bottom: 2px solid var(--color-frame);
    align-items: baseline;
  }
  .td-confused__item:last-child { border-bottom: 0; }
  .td-confused__pattern { min-width: 0; }
  .td-confused__link {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: var(--color-ink);
  }
  .td-confused__link:hover .td-confused__name {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--accent-td);
  }
  .td-confused__ref {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--color-ink-dim);
    font-feature-settings: "tnum";
  }
  .td-confused__name {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-base);
    letter-spacing: -0.01em;
    color: var(--color-ink);
    line-height: 1.1;
  }
  /* Free-phrase fallback — same two-row layout as a resolved link so
     the two modes share their vertical rhythm. */
  .td-confused__concept {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
  }
  .td-confused__concept-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .td-confused__phrase {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-base);
    line-height: 1.15;
    color: var(--color-ink);
  }
  .td-confused__distinction {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }
  @media (max-width: 720px) {
    .td-confused__item {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  /* Relationships grid — same grid approach as FM and RF. Row-aligned
     heights so two unequal RelatedEntries panels in the same row share
     an outer frame height. Uses the shared `.nsb-two-col--equal`
     utility (see globals.css) — the `.nsb-related` height rule lives
     there. */
</style>
