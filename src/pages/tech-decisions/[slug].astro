---
import DetailLayout from "@/layouts/DetailLayout.astro";
import { findEntry, listEntries } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";

export async function getStaticPaths() {
  ensureValidated();
  return listEntries("TD").map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = slug ? findEntry("TD", slug) : undefined;
if (!entry) {
  throw new Error(`Tech Decision not found for slug "${slug}"`);
}
const sub = (entry as any).family as string | undefined;
---
<DetailLayout
  code="TD"
  title={entry.title}
  summary={entry.summary}
  subcategory={sub}
>
  <div class="nsb-placeholder">
    Phase 1 placeholder · Tech Decision detail page for "{entry.slug}".
    Comparison layout lands later.
  </div>
</DetailLayout>
