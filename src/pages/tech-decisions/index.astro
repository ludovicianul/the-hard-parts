---
/**
 * /tech-decisions — catalog landing page.
 *
 * Migrated onto the shared landing primitives. See EP/FM/RF landings
 * for equivalent structure. TD-specific notes:
 *
 *   · Card fill uses `severityIfWrong`, not a plain severity —
 *     the reader's scan question here is "how bad if I pick the
 *     wrong side of this trade-off", not "how serious is this by
 *     itself". Mapping goes through `severityCardFill` which
 *     defaults unmapped values to `medium`.
 *   · `reversibility` is surfaced as a reading-guide ladder even
 *     though a few entries carry free-form values (e.g. "depends on
 *     surface") — the off-scale values just render as plain text on
 *     the detail MetaRail.
 */
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import EntryCard from "@/components/EntryCard.astro";
import LandingIntroPanel from "@/components/LandingIntroPanel.astro";
import ReadingGuide from "@/components/ReadingGuide.astro";
import AttributeLegend from "@/components/AttributeLegend.astro";
import AttributeCard from "@/components/AttributeCard.astro";
import LandingGroup from "@/components/LandingGroup.astro";
import { loadTechDecisions } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import { formatRefCode } from "@/lib/resolve";
import {
  SEVERITY_SCALE,
  FREQUENCY_SCALE,
  REVERSIBILITY_SCALE,
  CONFIDENCE_SCALE,
  severityCardFill,
} from "@/lib/attribute-scales";

ensureValidated();

const file = loadTechDecisions();
const entries = file.entries;
const declaredSubcategories = file.category.categories;

// Group entries by subcategory in the declared order. TD subcategory
// values are slug-cased (e.g. "product-delivery") — prettify for
// display but keep the original in the data.
type Group = { key: string; entries: typeof entries };
const groups: Group[] = declaredSubcategories.map((key) => ({
  key,
  entries: entries.filter((e) => e.category === key),
}));
const orphaned = entries.filter((e) => !declaredSubcategories.includes(e.category));
if (orphaned.length > 0) groups.push({ key: "other", entries: orphaned });

const prettifySub = (s: string): string =>
  s.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");

// Catalog refcodes via the shared resolver so each card's mono
// reference number matches the target entry's own masthead pill.
const total = entries.length;
const refBySlug = new Map<string, string>();
entries.forEach((e, i) => {
  refBySlug.set(e.slug, formatRefCode("TD", i, total).refNum);
});
---
<CategoryLayout
  code="TD"
  heroTitle="Tech Decisions"
  tagline="Structured trade-off references for consequential engineering and product decisions — the kind where context matters more than ideology, and where the honest answer is almost always 'it depends, and here's on what'."
>
  <header class="nsb-landing-prelude" aria-label="About this catalog">
    <LandingIntroPanel>
      Each entry in this catalog is a <strong>trade-off</strong>, not a
      recommendation. Two concrete options are laid out side by side with
      their real conditions, costs, hidden costs, and the failure modes
      each invites when misapplied. The grid below groups decisions by
      the <em>axis</em> of the call &mdash; architecture shape, delivery
      posture, team model, quality bar, AI systems &mdash; not by the
      kind of team making it. Card weight reflects
      <strong>severity if wrong</strong> on a five-step grayscale ramp
      &mdash; paper at <em>low</em>, near-black at <em>critical</em>.
    </LandingIntroPanel>

    <ReadingGuide>
      <AttributeLegend
        title="Severity if wrong"
        scale={SEVERITY_SCALE}
        footerNote="Chip = card fill on the grid."
      />
      <AttributeCard
        title="Frequency"
        description="How often this decision actually shows up in real engineering work — from rare architectural bets to universal team questions."
        scale={FREQUENCY_SCALE}
        trendNote={{
          label: "increasing",
          caption: "Not a point on the scale — a trend. Flags decisions whose prevalence is rising (often AI-era).",
        }}
      />
      <AttributeCard
        title="Reversibility"
        description="How hard it is to undo this decision once taken — from cheap to walk back, to a one-way door you'll live with for years."
        scale={REVERSIBILITY_SCALE}
      />
      <AttributeCard
        title="Confidence"
        description="How sure we are the framing here holds up across teams — provisional vs. repeatedly observed trade-offs."
        scale={CONFIDENCE_SCALE}
      />
    </ReadingGuide>
  </header>

  {groups.map((group, gi) => group.entries.length > 0 && (
    <LandingGroup
      id={`subcat-${group.key}`}
      ariaLabel={`Tech Decisions · ${group.key}`}
      eyebrow={`Class ${String(gi + 1).padStart(2, "0")}`}
      title={prettifySub(group.key)}
      countLabel={`${String(group.entries.length).padStart(2, "0")} ${group.entries.length === 1 ? "decision" : "decisions"}`}
    >
      {group.entries.map((e) => (
        /* Severity-weight fill via `severityIfWrong`. Falls back to
           `medium` when absent so the grid never renders a blank card. */
        <EntryCard
          code="TD"
          slug={e.slug}
          title={e.title}
          summary={e.summary}
          subcategory={prettifySub(e.category)}
          severity={severityCardFill(e.severityIfWrong)}
          refNum={refBySlug.get(e.slug)}
          fillFromSeverity
          metaBits={[
            /* Reversibility is deliberately NOT duplicated here — it's
               a first-class dimension on the detail page's MetaRail.
               Frequency stays because it's the single most useful
               "should I open this entry now?" signal on the grid. */
            e.frequency ? `Freq · ${e.frequency}` : undefined,
          ].filter((s): s is string => typeof s === "string")}
        />
      ))}
    </LandingGroup>
  ))}
</CategoryLayout>
