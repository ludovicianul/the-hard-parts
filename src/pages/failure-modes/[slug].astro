---
import DetailLayout from "@/layouts/DetailLayout.astro";
import AtAGlance from "@/components/AtAGlance.astro";
import CalloutBand from "@/components/CalloutBand.astro";
import HeardInTheWild from "@/components/HeardInTheWild.astro";
import LabeledList from "@/components/LabeledList.astro";
import MetaRail from "@/components/MetaRail.astro";
import OperatorNotes from "@/components/OperatorNotes.astro";
import RelatedEntries from "@/components/RelatedEntries.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import SectionIndex from "@/components/SectionIndex.astro";
import Tag from "@/components/Tag.astro";
import WarningSignsByStage from "@/components/WarningSignsByStage.astro";
import { loadFailureModes } from "@/lib/load";
import { formatRefCode, resolveSlug } from "@/lib/resolve";
import { ensureValidated } from "@/lib/validate";
import type { FailureModeEntry } from "@/content/schemas/failure-mode";
import {
  SEVERITY_SCALE,
  FREQUENCY_SCALE,
  RECOVERY_SCALE,
  CONFIDENCE_SCALE,
  barCounts,
  isFrequencyTrend,
  severityTagVariant,
} from "@/lib/attribute-scales";

export async function getStaticPaths() {
  ensureValidated();
  return loadFailureModes().entries.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry: FailureModeEntry | undefined = loadFailureModes().entries.find(
  (e) => e.slug === slug,
);
if (!entry) {
  throw new Error(`Failure Mode not found for slug "${slug}"`);
}

// Section visibility — each of these resolves independently so the page
// never renders an empty section or an orphaned anchor.
const hasAiBlock = Boolean(
  (entry.aiCanHelpWith && entry.aiCanHelpWith.length > 0) ||
    (entry.aiCanMakeWorseBy && entry.aiCanMakeWorseBy.length > 0) ||
    entry.aiFalseConfidence ||
    entry.aiSpecificNotes,
);

const hasVoice = Boolean(entry.commonQuote && entry.commonQuote.trim().length > 0);

const hasOperatorNotes = Boolean(
  entry.bestMomentToIntervene ||
    entry.counterMove ||
    entry.falsePositive,
);

// New FM-schema fields (all optional). Each of these drives a piece
// of UI that only renders when the entry populates it — a pattern
// we already use for AI / voice / operator notes.
const hasLooksHealthy = Boolean(
  entry.looksHealthyBecause && entry.looksHealthyBecause.length > 0,
);
const hasEasilyConfused = Boolean(
  entry.easilyConfusedWith && entry.easilyConfusedWith.length > 0,
);
const hasInterventionStrip = Boolean(
  entry.firstMove || entry.hardTradeoff || entry.recoveryTrap,
);

// Resolve each `easilyConfusedWith[].pattern` eagerly at build time.
// `pattern` is allowed to be a FM slug OR a short human phrase; the
// resolver returns a ResolvedRef for slugs and undefined for phrases.
// The template uses the resolved ref to render a link + refCode pill
// when possible, and falls back to the raw string as italic-serif
// text otherwise. No runtime cost — this is a static map.
const easilyConfusedResolved = (entry.easilyConfusedWith ?? []).map((item) => ({
  raw: item.pattern,
  distinction: item.distinction,
  ref: resolveSlug(item.pattern),
}));

// Reference code — stable catalog number for this FM. Comes from the
// shared `formatRefCode` helper in `lib/resolve.ts`, which is the same
// function that stamps cross-reference links elsewhere on the site, so
// the pill on this masthead and the "FM-05 · Hero Trap" cell on every
// page that links here are guaranteed to match. Rendered as the black
// pill on the tabloid masthead and in the AT-A-GLANCE block below.
const allFm = loadFailureModes().entries;
const indexInFile = allFm.findIndex((e) => e.slug === entry.slug);
const { refCode } = formatRefCode("FM", indexInFile, allFm.length);

// Severity → pill variant on the masthead. Uses the shared
// `severityTagVariant` helper so the pill color matches the card fill
// color a reader just saw on the FM landing grid — and so a future
// rename of the `sev-*` Tag variants flows through one place only.
const severityPillVariant = severityTagVariant(entry.severity);

// Section index — only include sections that will actually render.
// Step numbers are computed positionally so removing/adding a conditional
// section keeps the remaining steps correctly sequenced.
const sectionSpecs: Array<{ id: string; label: string; shown: boolean }> = [
  { id: "sec-definition",      label: "Definition",        shown: true },
  { id: "sec-arc",             label: "How it unfolds",    shown: true },
  { id: "sec-recognition",     label: "Warning signs",     shown: true },
  { id: "sec-causes",          label: "Why it happens",    shown: true },
  { id: "sec-response",        label: "Response",          shown: true },
  { id: "sec-ai",              label: "AI impact",         shown: hasAiBlock },
  { id: "sec-relationships",   label: "Relationships",     shown: true },
  { id: "sec-voice",           label: "Heard in the wild", shown: hasVoice },
  { id: "sec-operator-notes",  label: "Notes from practice", shown: hasOperatorNotes },
];
const sections = sectionSpecs
  .filter((s) => s.shown)
  .map((s, i) => ({
    step: String(i + 1).padStart(2, "0"),
    id: s.id,
    label: s.label,
  }));

// Map step codes into the actual section headers.
const stepFor = (id: string) => sections.find((s) => s.id === id)?.step ?? "";

---
<DetailLayout
  code="FM"
  title={entry.title}
  summary={entry.summary}
  subcategory={entry.category}
  refCode={refCode}
>
  {/* Header meta-bar — tabloid pill row. Severity (color-coded) +
      frequency (outline), matching the TD and RF detail mastheads so
      all three categories carry the same two-pill rhythm at the top.
      Lifecycle is NOT repeated here — it lives on the MetaRail below
      as a first-class dimension, and a masthead pill would duplicate
      the same information the reader sees immediately after. */}
  <Fragment slot="header-stamp">
    <Tag label={`Severity ${entry.severity}`} variant={severityPillVariant} size="sm" />
    {entry.frequency && <Tag label={`Freq ${entry.frequency}`} variant="outline" size="sm" />}
  </Fragment>

  {/* Local navigation rail (sticky on desktop, collapsible on mobile) */}
  <Fragment slot="nav-rail">
    <SectionIndex items={sections} eyebrow="In this entry" />
  </Fragment>

  {/* 1. Snapshot metadata rail — the severity cell is filled with its own
         ramp color so a reader's eye sees the same hue as the landing-grid
         card and the masthead pill. Each ordinal attribute also carries a
         rising-bar indicator computed from the shared scales (same ladders
         used on the FM landing "reading guide" cards). Lifecycle is left
         bar-less because it is a list of stage names, not an ordinal. */}
  <MetaRail
    items={[
      {
        label: "Severity",
        value: entry.severity,
        severity: entry.severity,
        scale: barCounts(SEVERITY_SCALE, entry.severity),
      },
      {
        label: "Frequency",
        value: entry.frequency,
        /* "increasing" is a trajectory, not a ladder position — render
           it as a trend arrow instead of bars. Everything else uses
           the 5-step ladder. */
        ...(isFrequencyTrend(entry.frequency)
          ? { trend: "increasing" as const }
          : { scale: barCounts(FREQUENCY_SCALE, entry.frequency) }),
      },
      { label: "Lifecycle", value: entry.lifecycleStages },
      {
        label: "Recovery",
        value: entry.recoveryDifficulty,
        scale: barCounts(RECOVERY_SCALE, entry.recoveryDifficulty),
      },
      {
        label: "Confidence",
        value: entry.patternConfidence,
        scale: barCounts(CONFIDENCE_SCALE, entry.patternConfidence),
      },
    ]}
  />

  {/* 2. AT A GLANCE — shared blue-fill identity panel. See
      `@/components/AtAGlance.astro` for the visual contract; this page
      just passes the FM-specific identity fields. Empty rows are
      silently dropped by the component, so no outer guard is needed. */}
  <AtAGlance
    refCode={refCode}
    rows={[
      { label: "Also known as",     value: entry.alternativeNames },
      { label: "First noticed by",  value: entry.whoNoticesFirst },
      { label: "Mistaken for",      value: entry.mistakenFor },
      { label: "Often mistaken as", value: entry.oftenMistakenAs },
    ]}
  />

  {/* "Why it looks healthy" — the external, scannable recognition
      axis. Sits directly below AT-A-GLANCE because it belongs to
      identity / recognition, not to diagnosis. Rendered with the
      boxed LabeledList variant so it reads as part of the same
      identity strip as the blue glance panel above. Only renders
      when populated — missing fields degrade silently. */}
  {hasLooksHealthy && (
    <div class="fm-looks-healthy">
      <LabeledList
        variant="boxed"
        label="Why it looks healthy"
        caption="Concrete external tells that make the pattern read as responsible behavior."
        items={entry.looksHealthyBecause}
      />
    </div>
  )}

  {/* 3. What it is — definition */}
  <SectionHeader
    id="sec-definition"
    step={stepFor("sec-definition")}
    eyebrow="Definition"
    title="What it is"
    note={entry.blastRadius && entry.blastRadius.length > 0 ? `Blast radius: ${entry.blastRadius.join(" · ")}` : undefined}
  />
  <p class="fm-prose">{entry.whatItIs}</p>

  {/* 4. Story arc — the canonical four-beat narrative */}
  <SectionHeader
    id="sec-arc"
    step={stepFor("sec-arc")}
    eyebrow="How it unfolds"
    title="The arc of the pattern"
  />
  <ol class="fm-arc">
    <li class="fm-arc__beat">
      <div class="fm-arc__marker">
        <span class="fm-arc__num" aria-hidden="true">i</span>
        <p class="nsb-eyebrow fm-arc__code">Starts</p>
      </div>
      <p class="fm-prose">{entry.starts}</p>
    </li>
    <li class="fm-arc__beat">
      <div class="fm-arc__marker">
        <span class="fm-arc__num" aria-hidden="true">ii</span>
        <p class="nsb-eyebrow fm-arc__code">Feels reasonable because</p>
      </div>
      <p class="fm-prose">{entry.feelsReasonableBecause}</p>
    </li>
    <li class="fm-arc__beat">
      <div class="fm-arc__marker">
        <span class="fm-arc__num" aria-hidden="true">iii</span>
        <p class="nsb-eyebrow fm-arc__code">Escalates</p>
      </div>
      <p class="fm-prose">{entry.escalates}</p>
    </li>
    <li class="fm-arc__beat">
      <div class="fm-arc__marker">
        <span class="fm-arc__num" aria-hidden="true">iv</span>
        <p class="nsb-eyebrow fm-arc__code">Ends</p>
      </div>
      <p class="fm-prose">{entry.ends}</p>
    </li>
  </ol>

  {/* 5. Warning signs by stage */}
  <SectionHeader
    id="sec-recognition"
    step={stepFor("sec-recognition")}
    eyebrow="Recognition"
    title="Warning signs by stage"
    note="Observable signals as the pattern progresses."
  />
  <WarningSignsByStage warningSigns={entry.warningSigns} />

  {/* 6. Why it happens */}
  <SectionHeader
    id="sec-causes"
    step={stepFor("sec-causes")}
    eyebrow="Root causes"
    title="Why it happens"
  />
  <ul class="fm-list">
    {entry.whyItHappens.map((item) => <li>{item}</li>)}
  </ul>

  {/* 7. Response — immediate + structural + what not to do */}
  <SectionHeader
    id="sec-response"
    step={stepFor("sec-response")}
    eyebrow="Response"
    title="What to do"
    note="Immediate triage first, then structural fixes."
  />

  {/* Intervention strip — three short, pattern-specific cells above
      the generic action lists. Exists to make this section feel like
      intervention guidance (one move, one trade-off, one trap) rather
      than another bag of advice. Each cell renders only when its
      field is populated; the strip itself renders only if at least
      one of the three is present. Visually matches the `.fm-response`
      3-cell grid so the two blocks read as a stacked pair. */}
  {hasInterventionStrip && (
    <div class="fm-intervention" aria-label="Intervention">
      {entry.firstMove && (
        <div class="fm-intervention__cell">
          <p class="nsb-eyebrow fm-intervention__label">First move</p>
          <p class="fm-intervention__body">{entry.firstMove}</p>
        </div>
      )}
      {entry.hardTradeoff && (
        <div class="fm-intervention__cell">
          <p class="nsb-eyebrow fm-intervention__label">Hard trade-off</p>
          <p class="fm-intervention__body">{entry.hardTradeoff}</p>
        </div>
      )}
      {entry.recoveryTrap && (
        <div class="fm-intervention__cell fm-intervention__cell--warn">
          <p class="nsb-eyebrow fm-intervention__label">Recovery trap</p>
          <p class="fm-intervention__body">{entry.recoveryTrap}</p>
        </div>
      )}
    </div>
  )}

  <div class="fm-response">
    <div class="fm-response__col">
      <p class="nsb-eyebrow">Immediate actions</p>
      <ul class="fm-list">
        {entry.immediateActions.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="fm-response__col">
      <p class="nsb-eyebrow">Structural fixes</p>
      <ul class="fm-list">
        {entry.structuralFixes.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    {entry.whatNotToDo && entry.whatNotToDo.length > 0 && (
      <div class="fm-response__col fm-response__col--warn">
        <p class="nsb-eyebrow">What not to do</p>
        <ul class="fm-list fm-list--strike">
          {entry.whatNotToDo.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    )}
  </div>

  {/* 8. AI impact */}
  {hasAiBlock && (
    <>
      <SectionHeader
        id="sec-ai"
        step={stepFor("sec-ai")}
        eyebrow="AI impact"
        title="How AI distorts this pattern"
        note="Where AI-assisted workflows accelerate, hide, or help with this failure mode."
      />
      {/* AI section — unified site-wide treatment: two boxed
          LabeledLists side-by-side with equal row heights + blue-
          serif synthesis band below. See docs/launch-readiness.md
          §1 (shared primitives). `--equal` aligns the bottom edges
          of the two boxes even when one list is longer than the
          other. */}
      <div class="nsb-two-col nsb-two-col--equal">
        <LabeledList
          variant="boxed"
          label="AI can help with"
          items={entry.aiCanHelpWith}
        />
        <LabeledList
          variant="boxed"
          label="AI can make worse by"
          items={entry.aiCanMakeWorseBy}
        />
      </div>
      {entry.aiFalseConfidence && (
        /* Pattern-specific false-confidence warning. Red variant
           because this is a warning (the specific illusion AI
           creates inside this particular pattern), distinct from
           the blue synthesis below which is the editorial
           takeaway. The two bands are intentionally sequenced
           warning → synthesis, not synthesis → warning, so a
           reader sees the caution before the summary. */
        <CalloutBand label="AI false confidence" variant="red">
          <p>{entry.aiFalseConfidence}</p>
        </CalloutBand>
      )}
      {entry.aiSpecificNotes && (
        /* Blue serif synthesis band — matches TD and RF. Site-wide
           visual vocabulary: yellow = heuristic / imperative takeaway,
           blue = synthesis / summary position. aiSpecificNotes is the
           editorial synthesis of the two AI-effect lists above, so it
           belongs in the blue-serif treatment, not the yellow one. */
        <CalloutBand label="AI synthesis" variant="blue" serif>
          <p>{entry.aiSpecificNotes}</p>
        </CalloutBand>
      )}
    </>
  )}

  {/* 9. Relationships — causal (FM internal) and related (cross-category) */}
  <SectionHeader
    id="sec-relationships"
    step={stepFor("sec-relationships")}
    eyebrow="Relationships"
    title="Connected patterns"
    note="Causal flows inside Failure Modes, and related entries across the site."
  />

  {/* "Easy to confuse with" — recognition-boundary panel. Distinct
      from `oftenLeadsTo` / `oftenCausedBy` (causal) and from the
      cross-category related-entry grid (adjacency). This block is
      specifically about disambiguation: nearby patterns + one-line
      distinctions. Rendered at the TOP of the Relationships section
      so a reader who still isn't sure "am I looking at the right
      pattern?" reaches this before the cross-reference links. When
      a pattern name resolves to a real FM slug, the cell links to
      that detail page and shows its refCode pill; free-phrase
      patterns render as italic-serif plain text. */}
  {hasEasilyConfused && (
    <section class="fm-confused" aria-label="Easy to confuse with">
      <header class="fm-confused__head">
        <h3 class="fm-confused__title">Easy to confuse with</h3>
        <p class="fm-confused__note">
          Nearby patterns and how this one differs.
        </p>
      </header>
      <ul class="fm-confused__list">
        {easilyConfusedResolved.map((item) => (
          <li class="fm-confused__item">
            <div class="fm-confused__pattern">
              {item.ref ? (
                <a class="fm-confused__link" href={item.ref.href}>
                  <span class="fm-confused__ref">{item.ref.refCode}</span>
                  <span class="fm-confused__name">{item.ref.title}</span>
                </a>
              ) : (
                <span class="fm-confused__phrase">{item.raw}</span>
              )}
            </div>
            <p class="fm-confused__distinction">{item.distinction}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  <div class="nsb-two-col nsb-two-col--equal">
    <RelatedEntries
      eyebrow="Often leads to"
      title="Often leads to"
      refs={entry.oftenLeadsTo}
      expectCategory="FM"
      dense
    />
    <RelatedEntries
      eyebrow="Often caused by"
      title="Often caused by"
      refs={entry.oftenCausedBy}
      expectCategory="FM"
      dense
    />
    <RelatedEntries
      eyebrow="Related red flags"
      title="Related red flags"
      refs={entry.relatedRedFlags}
      expectCategory="RF"
      dense
    />
    <RelatedEntries
      eyebrow="Related tech decisions"
      title="Related tech decisions"
      refs={entry.relatedTechDecisions}
      expectCategory="TD"
      dense
    />
    <RelatedEntries
      eyebrow="Related playbooks"
      title="Related playbooks"
      refs={entry.relatedPlaybooks}
      expectCategory="EP"
      dense
    />
    {entry.relatedFailureModes && entry.relatedFailureModes.length > 0 && (
      <RelatedEntries
        eyebrow="Also see"
        title="Also see"
        refs={entry.relatedFailureModes}
        expectCategory="FM"
        dense
      />
    )}
  </div>

  {/* Heard in the wild — the entry's voice / recognition moment.
      Holds commonQuote + whoSaysThis. One deliberate editorial beat on the
      page; tabloid-adjacent but still serious. */}
  {hasVoice && (
    <>
      <SectionHeader
        id="sec-voice"
        step={stepFor("sec-voice")}
        eyebrow="Heard in the wild"
        title="What it sounds like"
        note="The phrase that signals the pattern is about to start — and who tends to say it."
      />
      <HeardInTheWild
        quote={entry.commonQuote}
        attribution={entry.whoSaysThis}
      />
    </>
  )}

  {/* Notes from practice — hard-won practical annotations.
      Holds bestMomentToIntervene + counterMove + falsePositive. Typed field-
      manual register, not quote content. The internal section id and the
      component class prefix (`fm-ops`) keep their original names so that
      in-page anchors, scroll-spy, and existing CSS selectors aren't broken
      by the editorial rename. */}
  {hasOperatorNotes && (
    <>
      <SectionHeader
        id="sec-operator-notes"
        step={stepFor("sec-operator-notes")}
        eyebrow="Notes from practice"
        title="From someone who's been in the room"
        note="Annotations from engineers who have worked this pattern before."
      />
      <OperatorNotes
        items={[
          {
            label: "Best moment",
            hint: "When intervention actually changes the trajectory.",
            body: entry.bestMomentToIntervene,
          },
          {
            label: "Counter move",
            hint: "The specific action that breaks the pattern.",
            body: entry.counterMove,
          },
          {
            label: "False positive",
            hint: "When this pattern is actually the correct call.",
            body: entry.falsePositive,
          },
        ]}
      />
    </>
  )}
</DetailLayout>

<style>
  /* =====================================================================
     TABLOID BODY STYLES FOR THE FM DETAIL PAGE
     --------------------------------------------------------------------- */

  /* AT A GLANCE blue panel moved to `@/components/AtAGlance.astro`
     (shared with TD and RF). The component owns all `nsb-glance__*`
     styles; no FM-local CSS is needed for that block. */

  /* ---- prose body text in sections --------------------------------
     Short reference-style paragraphs (1–3 sentences). NO `max-width`
     cap here — the detail content column is ~800px, and any prose
     cap narrower than that (previously 70ch ≈ 595px) produced the
     "disciplined migration strategy." style dangling last line we
     kept trying to balance away. With the cap removed the sentence
     fits naturally inside its column and `text-wrap: balance` can
     actually work. `pretty` stays as a fallback for older browsers. */
  .fm-prose {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-ink);
    margin: var(--space-4) 0 0 0;
    text-wrap: pretty;
  }
  @supports (text-wrap: balance) {
    .fm-prose { text-wrap: balance; }
  }

  /* ---- Story arc — four beats framed as a black-bordered panel with
     a black title bar, each beat a row with a big bold roman numeral. -- */
  .fm-arc {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0 0;
    display: grid;
    gap: 0;
    border: 3px solid var(--color-frame);
    background: var(--color-surface);
  }
  .fm-arc__beat {
    display: grid;
    grid-template-columns: 5rem minmax(10rem, 15rem) 1fr;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-5);
    border-bottom: 2px solid var(--color-frame);
    align-items: baseline;
  }
  .fm-arc__beat:last-child { border-bottom: 0; }
  .fm-arc__marker {
    display: contents;
  }
  .fm-arc__num {
    font-family: var(--font-sans);
    font-size: 2.25rem;
    line-height: 1;
    color: var(--color-surface);
    background: var(--color-frame);
    font-weight: 900;
    font-feature-settings: "tnum";
    padding: 8px 10px;
    text-transform: uppercase;
    text-align: center;
    justify-self: start;
    align-self: start;
  }
  .fm-arc__code {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-weight: 900;
    color: var(--accent-fm);
  }
  .fm-arc__beat .fm-prose { margin: 0; }
  @media (max-width: 720px) {
    .fm-arc__beat {
      grid-template-columns: auto 1fr;
      gap: var(--space-3);
    }
    .fm-arc__code { grid-column: 2; }
    .fm-arc__beat > .fm-prose { grid-column: 1 / -1; }
  }

  /* ---- plain bulleted lists (structural fixes, root causes, etc.) -- */
  .fm-list {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .fm-list li {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    padding-left: 1.25rem;
    position: relative;
  }
  /* Solid black square bullet — matches the tabloid frames. Sits slightly
     higher than the text baseline so it reads as a structural block, not a
     typographic glyph. */
  .fm-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 7px;
    height: 7px;
    background: var(--color-frame);
  }
  /* "What not to do" list — yellow square on red background. */
  .fm-list--strike li { color: inherit; }
  .fm-list--strike li::before {
    background: var(--color-yellow);
  }

  /* ---- Response columns: three framed cells, what-not-to-do in RED - */
  .fm-response {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0;
    margin-top: var(--space-5);
    border: 3px solid var(--color-frame);
    background: var(--color-surface);
  }
  .fm-response__col {
    padding: var(--space-5);
    background: var(--color-surface);
    border-right: 2px solid var(--color-frame);
  }
  .fm-response__col:last-child { border-right: 0; }
  .fm-response__col > .nsb-eyebrow {
    margin: 0 0 var(--space-3) 0;
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
