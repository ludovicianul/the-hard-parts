---
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import { listEntries } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import { hrefForEntry } from "@/lib/categories";

ensureValidated();
const entries = listEntries("FM");
---
<CategoryLayout code="FM">
  <div class="nsb-placeholder">
    Phase 1 placeholder · /failure-modes landing page.
    Real card grid, filter bar, and category-specific components arrive in
    Phase 2. Below is a raw link list proving loader + routing work.
  </div>

  <ul class="nsb-index-list">
    {entries.map((e) => (
      <li>
        <a href={hrefForEntry("FM", e.slug)}>{e.title}</a>
        <span class="nsb-index-sub"> · {e.category}</span>
      </li>
    ))}
  </ul>

  <style is:global>
    .nsb-index-list {
      margin-top: var(--space-6);
      list-style: none;
      padding: 0;
      font-family: var(--font-sans);
    }
    .nsb-index-list li {
      padding-block: var(--space-3);
      border-bottom: var(--rule-soft);
    }
    .nsb-index-sub {
      color: var(--color-ink-faint);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
    }
  </style>
</CategoryLayout>
