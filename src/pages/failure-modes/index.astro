---
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import EntryCard from "@/components/EntryCard.astro";
import AttrGlyph from "@/components/AttrGlyph.astro";
import { loadFailureModes } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import {
  SEVERITY_SCALE,
  FREQUENCY_SCALE,
  RECOVERY_SCALE,
  CONFIDENCE_SCALE,
} from "@/lib/attribute-scales";

ensureValidated();

const file = loadFailureModes();
const entries = file.entries;
const declaredSubcategories = file.category.categories;

// Group entries by subcategory, preserving the declared order from the
// category block. Entries whose category is (unexpectedly) not in the
// declared list fall into an "other" bucket, surfaced visibly — the
// validator already blocks any real drift, so in practice this is empty.
type Group = { key: string; label: string; entries: typeof entries };
const groups: Group[] = declaredSubcategories.map((key) => ({
  key,
  label: key,
  entries: entries.filter((e) => e.category === key),
}));
const orphaned = entries.filter((e) => !declaredSubcategories.includes(e.category));
if (orphaned.length > 0) {
  groups.push({ key: "other", label: "other", entries: orphaned });
}

const titleCase = (s: string): string =>
  s ? s.charAt(0).toUpperCase() + s.slice(1) : s;

// Build a stable 3-digit reference number per entry, in the original file
// order. Used on cards as a catalog call-number.
const refByIndex = new Map<string, string>();
entries.forEach((e, i) => {
  refByIndex.set(e.slug, String(i + 1).padStart(3, "0"));
});

// The three ordinal "attribute" cards rendered alongside the Severity
// legend panel (see below). Each card is a framed box with the title and
// description on the left and the bar-scale ladder on the right. Scales
// are imported from the shared `attribute-scales.ts` so this page and the
// detail MetaRail stay in lockstep.
//
// `trendNote` is optional — only Frequency carries one today. It surfaces
// the "increasing" trajectory value as a separate footer row rendered
// with the up-right chevron glyph used on the detail page's MetaRail
// trend marker. The chevron stays because it conveys trajectory info
// the text alone doesn't; per-attribute *type* icons were removed
// because they read as decoration rather than signal.
const attributeKeys: readonly {
  title: string;
  description: string;
  scale: readonly string[];
  trendNote?: { label: string; caption: string };
}[] = [
  {
    title: "Frequency",
    description: "How often this pattern actually shows up in practice — from rare one-offs to near-universal.",
    scale: FREQUENCY_SCALE,
    trendNote: {
      label: "increasing",
      caption: "Not a point on the scale — a trend. Flags patterns whose prevalence is rising (often AI-era).",
    },
  },
  {
    title: "Recovery",
    description: "How hard it is to climb back out once you are in it — tactical fix vs. structural teardown.",
    scale: RECOVERY_SCALE,
  },
  {
    title: "Confidence",
    description: "How sure we are the pattern is real and consistent — provisional vs. repeatedly observed.",
    scale: CONFIDENCE_SCALE,
  },
];
---

<CategoryLayout
  code="FM"
  tagline="Named failure patterns that recur in software engineering — how they start, how they escalate, what they look like at each stage, and what good responses look like."
>
  <header class="fm-landing__intro" aria-label="About this catalog">
    {/* Row 1 — full-width intro paragraph. */}
    <p class="fm-landing__intro-text">
      The catalog is grouped by where the pattern lives &mdash; planning, people,
      technical, process, leadership, AI-specific. Each entry carries a
      severity rating shown two ways: as a <strong>five-step bar</strong> on
      the card and as the card&rsquo;s own <strong>weight</strong> &mdash; the
      fill darkens through five grays from paper at <em>low</em> to near-black
      at <em>critical</em>. Color is reserved for category identity; severity
      reads purely as gravity. Scan the grid for weight first, then read the
      names.
    </p>

    {/* Row 2 — 2×2 reading-guide block. Severity gets its own
         distinctive styling (black title bar with yellow "SEVERITY KEY"
         eyebrow, vertical list of levels with bars + color chip,
         yellow footer note). The three other attributes use a lighter
         framed card with title and description on the left and a bar
         ladder on the right — a different internal layout from
         severity so the two kinds of information feel distinct. --- */}
    <ul class="fm-landing__attr-row" aria-label="Reading guide">
      {/* 1. Severity — distinctive "legend panel" look. */}
      <li class="fm-landing__legend">
        <p class="fm-landing__legend-head">Severity key</p>
        <ul class="fm-landing__legend-list">
          {SEVERITY_SCALE.map((level, i) => (
            <li class="fm-landing__legend-item">
              <span class="fm-landing__legend-bars" aria-hidden="true">
                {SEVERITY_SCALE.map((_, j) => (
                  <span class:list={["fm-landing__legend-bar", { "is-on": j <= i }]} />
                ))}
              </span>
              <span class="fm-landing__legend-label">{level}</span>
              <span
                class:list={["fm-landing__legend-chip", `fm-landing__legend-chip--${level}`]}
                aria-hidden="true"
                title={`card fill for ${level}`}
              />
            </li>
          ))}
        </ul>
        <p class="fm-landing__legend-foot">Chip = card fill on the grid.</p>
      </li>

      {/* 2. Three ordinal attributes — text-left / bars-right. When
             a card carries a `trendNote`, it appears in the text
             column below the description — a short line that defines
             the trend glyph (the up-right chevron) so a reader sees
             this symbol before encountering it in the catalog. */}
      {attributeKeys.map((a) => (
        <li class="fm-landing__attr">
          <div class="fm-landing__attr-text">
            <h3 class="fm-landing__attr-title">{a.title}</h3>
            <p class="fm-landing__attr-desc">{a.description}</p>
            {a.trendNote && (
              <p class="fm-landing__attr-trend">
                <span class="fm-landing__attr-trend-glyph" aria-hidden="true">
                  <AttrGlyph kind="increasing" size={14} />
                </span>
                <span class="fm-landing__attr-trend-body">
                  <span class="fm-landing__attr-trend-label">{a.trendNote.label}</span>
                  <span class="fm-landing__attr-trend-caption">{a.trendNote.caption}</span>
                </span>
              </p>
            )}
          </div>
          <ul class="fm-landing__attr-scale">
            {a.scale.map((level, i) => (
              <li class="fm-landing__attr-level">
                <span class="fm-landing__attr-bars" aria-hidden="true">
                  {a.scale.map((_, j) => (
                    <span class:list={["fm-landing__attr-bar", { "is-on": j <= i }]} />
                  ))}
                </span>
                <span class="fm-landing__attr-level-label">{level}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </header>

  {groups.map((group, gi) => group.entries.length > 0 && (
    <section class="fm-landing__group" aria-label={`Failure modes · ${group.label}`}>
      <header class="fm-landing__group-head">
        <span class="fm-landing__group-code">CLASS {String(gi + 1).padStart(2, "0")}</span>
        <h2 class="nsb-display fm-landing__group-title">{titleCase(group.label)}</h2>
        <span class="fm-landing__group-count">
          {String(group.entries.length).padStart(2, "0")} {group.entries.length === 1 ? "entry" : "entries"}
        </span>
      </header>

      <div class="fm-landing__grid">
        {group.entries.map((e) => (
          /* Card fill is driven entirely by severity — a five-step
             grayscale weight ramp from paper (low) down to near-black
             (critical). See EntryCard `fillFromSeverity` + tokens.css
             §Severity ramp. */
          <EntryCard
            code="FM"
            slug={e.slug}
            title={e.title}
            summary={e.summary}
            subcategory={e.category}
            severity={e.severity as "low" | "medium" | "medium-high" | "high" | "critical"}
            refNum={refByIndex.get(e.slug)}
            fillFromSeverity
            metaBits={[`Freq · ${e.frequency}`]}
          />
        ))}
      </div>
    </section>
  ))}
</CategoryLayout>

<style>
  /* ---- intro block ----------------------------------------------
     Three stacked rows: (1) intro paragraph, (2) attribute-key row
     of three framed boxes, (3) severity legend. Each row is
     full-width so nothing gets cramped. */
  .fm-landing__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin: 0 0 var(--space-7) 0;
  }
  .fm-landing__intro-text {
    font-family: var(--font-serif);
    font-size: clamp(var(--text-md), 1.4vw, var(--text-lg));
    line-height: var(--leading-snug);
    text-wrap: pretty;
    color: var(--color-ink);
    margin: 0;
    padding: var(--space-5);
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
    /* No reading-max cap — the panel itself owns the reading width. */
    max-width: none;
  }

  /* ---- Row 2: 2×2 reading-guide block ----------------------------
     The grid holds FOUR items: the Severity legend panel (distinct
     styling, see below) plus three plainer attribute cards. Locked
     to 2 columns at every tablet-and-up width so severity always
     sits next to a sibling; stacks into 1 column on mobile. --- */
  .fm-landing__attr-row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .fm-landing__attr-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ---- Attribute card (Frequency / Recovery / Confidence) -------
     Inside the card: text on the LEFT (title + description), bar
     ladder on the RIGHT. A 2-col grid; the bar column sizes to its
     content (`auto`) so the text column absorbs the rest of the
     width. On very narrow screens (when the 2×2 collapses to 1-col
     at < 640px) the internal split collapses too — text on top,
     bars below — to avoid a cramped sidebar. --- */
  .fm-landing__attr {
    background: var(--color-surface);
    border: 3px solid var(--color-frame);
    padding: var(--space-4) var(--space-5);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    min-width: 0;
    align-items: start;
  }
  @media (min-width: 420px) {
    .fm-landing__attr {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--space-5);
    }
  }
  .fm-landing__attr-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .fm-landing__attr-title {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    font-size: var(--text-sm);
    color: var(--color-ink);
  }
  .fm-landing__attr-desc {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--color-ink-dim);
  }
  /* Trend note — the "increasing ↗" sub-row that appears below the
     Frequency description. Uses the same up-right chevron glyph that
     the detail MetaRail renders, so a reader sees the symbol here
     first and recognizes it later. A rule-above separates it from the
     description without needing a colored panel. */
  .fm-landing__attr-trend {
    margin: 0;
    padding-top: var(--space-3);
    border-top: 1.5px solid var(--color-rule);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2) var(--space-3);
    align-items: start;
    color: var(--color-ink);
  }
  .fm-landing__attr-trend-glyph {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-frame);
    color: var(--color-yellow);
    flex-shrink: 0;
  }
  .fm-landing__attr-trend-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .fm-landing__attr-trend-label {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .fm-landing__attr-trend-caption {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.78rem;
    line-height: var(--leading-snug);
    color: var(--color-ink-dim);
  }
  .fm-landing__attr-scale {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .fm-landing__attr-level {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .fm-landing__attr-bars {
    display: inline-flex;
    gap: 2px;
  }
  .fm-landing__attr-bar {
    width: 10px;
    height: 7px;
    background: var(--color-frame);
    opacity: 0.18;
    display: inline-block;
  }
  .fm-landing__attr-bar.is-on { opacity: 1; }
  .fm-landing__attr-level-label {
    color: var(--color-ink);
    white-space: nowrap;
  }

  /* ---- Severity legend panel --------------------------------------
     Restored distinctive styling to match the reference design:
       · black title bar with yellow "SEVERITY KEY" eyebrow
       · white body with level rows (bars · label · color chip)
       · yellow footer note explaining the chip
     Sits inside the same 2×2 grid cell as the attribute cards, so
     its outer size matches but the internal anatomy is deliberately
     different (three distinct bands vs. a single framed panel). */
  .fm-landing__legend {
    background: var(--color-surface);
    color: var(--color-ink);
    border: 3px solid var(--color-frame);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .fm-landing__legend-head {
    margin: 0;
    padding: var(--space-3) var(--space-4);
    background: var(--color-frame);
    color: var(--color-yellow);
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
  }
  .fm-landing__legend-list {
    list-style: none;
    padding: var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .fm-landing__legend-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .fm-landing__legend-bars { display: inline-flex; gap: 2px; }
  .fm-landing__legend-bar {
    width: 12px;
    height: 8px;
    background: var(--color-frame);
    opacity: 0.18;
    display: inline-block;
  }
  .fm-landing__legend-bar.is-on { opacity: 1; }
  /* The LITERAL card color for each severity level — chip and card
     read from the same --sev-* tokens so they cannot drift. */
  .fm-landing__legend-chip {
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--color-frame);
    display: inline-block;
  }
  .fm-landing__legend-chip--low         { background: var(--sev-low); }
  .fm-landing__legend-chip--medium      { background: var(--sev-medium); }
  .fm-landing__legend-chip--medium-high { background: var(--sev-medium-high); }
  .fm-landing__legend-chip--high        { background: var(--sev-high); }
  .fm-landing__legend-chip--critical    { background: var(--sev-critical); }
  /* Yellow footer — the "colored chip at the bottom" requested in
     feedback. Saturated yellow on dark ink carries the editorial
     signal-color language (same yellow used for the title eyebrow
     above, the header nav brand dot, and callout bands). */
  .fm-landing__legend-foot {
    margin: 0;
    padding: var(--space-2) var(--space-4) var(--space-3);
    border-top: 2px solid var(--color-frame);
    background: var(--color-yellow);
    color: var(--color-yellow-ink);
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  /* ---- chapter-style group header -------------------------------- */
  .fm-landing__group {
    margin-top: var(--space-9);
  }
  .fm-landing__group-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-5);
    background: var(--color-frame);
    color: var(--color-surface);
  }
  .fm-landing__group-code {
    font-family: var(--font-sans);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-size: var(--text-xs);
    color: var(--color-yellow);
    font-feature-settings: "tnum";
  }
  .fm-landing__group-title {
    color: var(--color-surface);
    font-size: clamp(var(--text-3xl), 5vw, 3.5rem);
    line-height: 0.95;
    margin: 0;
  }
  .fm-landing__group-count {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-yellow);
    font-feature-settings: "tnum";
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .fm-landing__group-head {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  /* ---- entry card grid ------------------------------------------- */
  .fm-landing__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--space-4);
  }
</style>
