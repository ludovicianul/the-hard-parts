---
/**
 * /failure-modes — catalog landing page.
 *
 * Migrated onto the shared landing primitives. See the EP/RF/TD
 * landings for the equivalent structure. What's FM-specific here:
 *
 *   · The severity legend is the cross-category shape everyone uses;
 *     FM was the first category to ship it so the tokens + legend
 *     anatomy were designed FM-first and later extracted.
 *   · The entry-card `subcategory` label is FM's raw category slug
 *     (e.g. "planning", "people"); no prettify pass because the FM
 *     subcategory values are already single-word lowercase.
 */
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import EntryCard from "@/components/EntryCard.astro";
import LandingIntroPanel from "@/components/LandingIntroPanel.astro";
import ReadingGuide from "@/components/ReadingGuide.astro";
import AttributeLegend from "@/components/AttributeLegend.astro";
import AttributeCard from "@/components/AttributeCard.astro";
import LandingGroup from "@/components/LandingGroup.astro";
import { loadFailureModes } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import {
  SEVERITY_SCALE,
  FREQUENCY_SCALE,
  RECOVERY_SCALE,
  CONFIDENCE_SCALE,
  severityCardFill,
} from "@/lib/attribute-scales";

ensureValidated();

const file = loadFailureModes();
const entries = file.entries;
const declaredSubcategories = file.category.categories;

// Group entries by subcategory, preserving the declared order.
// Entries with an unknown subcategory fall into an "other" bucket —
// defensive only, `ensureValidated()` rejects unknown values.
type Group = { key: string; entries: typeof entries };
const groups: Group[] = declaredSubcategories.map((key) => ({
  key,
  entries: entries.filter((e) => e.category === key),
}));
const orphaned = entries.filter((e) => !declaredSubcategories.includes(e.category));
if (orphaned.length > 0) groups.push({ key: "other", entries: orphaned });

const titleCase = (s: string): string =>
  s ? s.charAt(0).toUpperCase() + s.slice(1) : s;

// 3-digit zero-padded catalog index in authorial order, carried on
// each card as the little mono reference number.
const refByIndex = new Map<string, string>();
entries.forEach((e, i) => {
  refByIndex.set(e.slug, String(i + 1).padStart(3, "0"));
});
---
<CategoryLayout
  code="FM"
  tagline="Named failure patterns that recur in software engineering: how they start, how they escalate, what they look like at each stage, and what good responses look like."
>
  <header class="nsb-landing-prelude" aria-label="About this catalog">
    <LandingIntroPanel>
      The catalog is grouped by where the pattern lives: planning,
      people, technical, process, leadership, AI-specific. Each entry
      carries a severity rating shown two ways: as a
      <strong>five-step bar</strong> on the card and as the card&rsquo;s
      own <strong>weight</strong>. The fill darkens through five grays,
      from paper at <em>low</em> to near-black at <em>critical</em>.
      Color is reserved for category identity; severity reads purely as
      gravity. Scan the grid for weight first, then read the names.
    </LandingIntroPanel>

    <ReadingGuide>
      <AttributeLegend
        title="Severity key"
        scale={SEVERITY_SCALE}
        footerNote="Chip = card fill on the grid."
      />
      <AttributeCard
        title="Frequency"
        description="How often this pattern actually shows up in practice: from rare one-offs to near-universal."
        scale={FREQUENCY_SCALE}
        trendNote={{
          label: "increasing",
          caption: "Not a point on the scale. A trend. Flags patterns whose prevalence is rising (often AI-era).",
        }}
      />
      <AttributeCard
        title="Recovery"
        description="How hard it is to climb back out once you are in it: tactical fix vs. structural teardown."
        scale={RECOVERY_SCALE}
      />
      <AttributeCard
        title="Confidence"
        description="How sure we are the pattern is real and consistent: provisional vs. repeatedly observed."
        scale={CONFIDENCE_SCALE}
      />
    </ReadingGuide>
  </header>

  {groups.map((group, gi) => group.entries.length > 0 && (
    <LandingGroup
      id={`subcat-${group.key}`}
      ariaLabel={`Failure modes · ${group.key}`}
      eyebrow={`Class ${String(gi + 1).padStart(2, "0")}`}
      title={titleCase(group.key)}
      countLabel={`${String(group.entries.length).padStart(2, "0")} ${group.entries.length === 1 ? "entry" : "entries"}`}
    >
      {group.entries.map((e) => (
        /* Card fill is driven entirely by severity — a five-step
           grayscale weight ramp from paper (low) down to near-black
           (critical). See EntryCard `fillFromSeverity`. */
        <EntryCard
          code="FM"
          slug={e.slug}
          title={e.title}
          summary={e.summary}
          subcategory={e.category}
          severity={severityCardFill(e.severity)}
          refNum={refByIndex.get(e.slug)}
          fillFromSeverity
          metaBits={[`Freq · ${e.frequency}`]}
        />
      ))}
    </LandingGroup>
  ))}
</CategoryLayout>
