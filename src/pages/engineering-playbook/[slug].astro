---
import DetailLayout from "@/layouts/DetailLayout.astro";
import { findEntry, listEntries } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";

export async function getStaticPaths() {
  ensureValidated();
  return listEntries("EP").map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = slug ? findEntry("EP", slug) : undefined;
if (!entry) {
  throw new Error(`Playbook not found for slug "${slug}"`);
}
const sub = (entry as any).category as string | undefined;
---
<DetailLayout
  code="EP"
  title={entry.title}
  summary={entry.summary}
  subcategory={sub}
>
  <div class="nsb-placeholder">
    Phase 1 placeholder · Engineering Playbook detail page for "{entry.slug}".
    Step-flow layout lands later.
  </div>
</DetailLayout>
