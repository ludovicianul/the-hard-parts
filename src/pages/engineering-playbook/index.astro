---
/**
 * /engineering-playbook — catalog landing page.
 *
 * Migrated onto the shared landing primitives:
 *   · <LandingIntroPanel>  — the serif framed intro paragraph
 *   · <ReadingGuide>       — the 2-col grid wrapper
 *   · <AttributeLegend>    — the Difficulty legend tile
 *   · <AttributeCard>      — the Confidence attribute tile
 *   · <LandingGroup>       — black masthead bar + auto-fit card grid
 *   · `.nsb-landing-prelude` — the flex-column outer header wrapper
 *
 * No category-scoped landing CSS remains here; everything visual now
 * flows from the shared primitives. The page's job is editorial
 * orientation + data glue only.
 */
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import EntryCard from "@/components/EntryCard.astro";
import LandingIntroPanel from "@/components/LandingIntroPanel.astro";
import ReadingGuide from "@/components/ReadingGuide.astro";
import AttributeLegend from "@/components/AttributeLegend.astro";
import AttributeCard from "@/components/AttributeCard.astro";
import LandingGroup from "@/components/LandingGroup.astro";
import { loadPlaybooks } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import { formatRefCode } from "@/lib/resolve";
import {
  DIFFICULTY_SCALE,
  CONFIDENCE_SCALE,
  severityCardFill,
} from "@/lib/attribute-scales";

ensureValidated();

const file = loadPlaybooks();
const entries = file.entries;
const declaredSubcategories = file.category.categories;

// Per-entry refNum via the shared resolver so cards carry the same
// "EP-01 / EP-02 / …" numbering as the masthead pill on the detail
// page and cross-references surfaced in other categories' pages.
const refBySlug = new Map<string, string>();
entries.forEach((e, i) => {
  refBySlug.set(e.slug, formatRefCode("EP", i, entries.length).refNum);
});

// Group entries by their subcategory field in the schema's declared
// order. Orphans fall into a trailing "other" bucket — defensive only,
// `ensureValidated()` already rejects unknown subcategory values.
type Group = { key: string; entries: typeof entries };
const groups: Group[] = declaredSubcategories.map((sub) => ({
  key: sub,
  entries: entries.filter((e) => e.category === sub),
}));
const orphaned = entries.filter((e) => !declaredSubcategories.includes(e.category));
if (orphaned.length > 0) groups.push({ key: "other", entries: orphaned });

const prettify = (s: string): string =>
  s.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ");
---
<CategoryLayout
  code="EP"
  heroTitle="Playbooks"
  tagline="Practical playbooks for recurring engineering situations — delivery, architecture, operations, team work, and AI adoption. Operational references you can actually execute, not motivational posts."
>
  <header class="nsb-landing-prelude" aria-label="About this reference">
    <LandingIntroPanel>
      Every entry is a <strong>structured procedure</strong> for a
      named situation: when to use it, when not to, what good looks
      like, the actual steps (with their purpose and outputs), common
      mistakes, artifacts, and success signals. Card weight reflects
      <strong>difficulty</strong> &mdash; harder playbooks darken the
      card.
    </LandingIntroPanel>

    <ReadingGuide>
      <AttributeLegend
        title="Difficulty key"
        scale={DIFFICULTY_SCALE}
        footerNote="Chip = card fill on the grid."
      />
      <AttributeCard
        title="Confidence"
        description="How sure we are the playbook works as written across teams and contexts — provisional vs. repeatedly validated in real engineering work."
        scale={CONFIDENCE_SCALE}
      />
    </ReadingGuide>
  </header>

  {groups.map((group, gi) => group.entries.length > 0 && (
    <LandingGroup
      id={`subcat-${group.key}`}
      ariaLabel={`Engineering Playbook · ${group.key}`}
      eyebrow={`Playbook set ${String(gi + 1).padStart(2, "0")}`}
      title={prettify(group.key)}
      countLabel={`${String(group.entries.length).padStart(2, "0")} ${group.entries.length === 1 ? "playbook" : "playbooks"}`}
    >
      {group.entries.map((e) => (
        /* Card meta carries `Owner · {primaryOwner}` — the single
           most useful "is this for me?" scan signal for EP. Time
           horizon + difficulty + roles all live on the detail
           MetaRail / AtAGlance. */
        <EntryCard
          code="EP"
          slug={e.slug}
          title={e.title}
          summary={e.summary}
          subcategory={prettify(e.category)}
          severity={severityCardFill(e.difficulty)}
          refNum={refBySlug.get(e.slug)}
          fillFromSeverity
          metaBits={[
            e.primaryOwner ? `Owner · ${e.primaryOwner}` : undefined,
          ].filter((s): s is string => typeof s === "string")}
        />
      ))}
    </LandingGroup>
  ))}
</CategoryLayout>
