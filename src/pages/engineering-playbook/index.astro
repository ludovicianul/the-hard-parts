---
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import { listEntries } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import { hrefForEntry } from "@/lib/categories";

ensureValidated();
const entries = listEntries("EP");
---
<CategoryLayout code="EP">
  <div class="nsb-placeholder">
    Phase 1 placeholder · /engineering-playbook landing page.
    Procedural index lands later.
  </div>

  <ul class="nsb-index-list">
    {entries.map((e) => (
      <li>
        <a href={hrefForEntry("EP", e.slug)}>{e.title}</a>
        <span class="nsb-index-sub"> · {(e as any).category}</span>
      </li>
    ))}
  </ul>
</CategoryLayout>
