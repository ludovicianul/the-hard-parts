---
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import { listEntries } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";
import { hrefForEntry } from "@/lib/categories";

ensureValidated();
const entries = listEntries("RF");
---
<CategoryLayout code="RF">
  <div class="nsb-placeholder">
    Phase 1 placeholder · /red-flags landing page.
    Signal-oriented scan layout lands later.
  </div>

  <ul class="nsb-index-list">
    {entries.map((e) => (
      <li>
        <a href={hrefForEntry("RF", e.slug)}>{e.title}</a>
        <span class="nsb-index-sub"> · {(e as any).layer}</span>
      </li>
    ))}
  </ul>
</CategoryLayout>
