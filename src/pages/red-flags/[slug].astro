---
import DetailLayout from "@/layouts/DetailLayout.astro";
import { findEntry, listEntries } from "@/lib/load";
import { ensureValidated } from "@/lib/validate";

export async function getStaticPaths() {
  ensureValidated();
  return listEntries("RF").map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = slug ? findEntry("RF", slug) : undefined;
if (!entry) {
  throw new Error(`Red Flag not found for slug "${slug}"`);
}
const sub = (entry as any).layer as string | undefined;
---
<DetailLayout
  code="RF"
  title={entry.title}
  summary={entry.summary}
  subcategory={sub}
>
  <div class="nsb-placeholder">
    Phase 1 placeholder · Red Flag detail page for "{entry.slug}".
    Signal / inspect-next layout lands later.
  </div>
</DetailLayout>
