---
import "@/styles/globals.css";
import { CATEGORIES, CATEGORY_ORDER } from "@/lib/categories";

export interface Props {
  title: string;
  description?: string;
  /** One of "fm" | "td" | "rf" | "ep" — sets the current page accent. */
  accent?: "fm" | "td" | "rf" | "ep";
}

const { title, description, accent } = Astro.props;

/**
 * Nav-only display override for category names.
 *
 * The canonical product name for EP is "Engineering Playbook" — it's
 * used on the category hero, the detail masthead, meta descriptions
 * and SEO. In the top nav, though, it's the longest of the four and
 * was forcing the bar to overflow at common laptop widths. The nav
 * shortens it to "Playbooks" (noun, matches the countLabel already
 * used on the landing grid). Every other surface keeps the full
 * canonical name. */
const NAV_NAME_OVERRIDES: Partial<Record<keyof typeof CATEGORIES, string>> = {
  EP: "Playbooks",
};

// Canonical product strings used in <title>, <meta>, OG cards. Keeping
// them here so every route gets the same editorial framing without
// each page reinventing it.
const SITE_NAME = "thehardparts.dev";
const SITE_TAGLINE =
  "The Hard Parts \u2014 an engineering reference for recurring software failures, warning signals, hard decisions, and practical playbooks.";
const fullTitle = title === SITE_NAME ? title : `${title} · ${SITE_NAME}`;
const metaDescription = description ?? SITE_TAGLINE;

// Canonical URL computed from the build-time origin + the current
// request path. Safe even when the origin is a file:// build (Astro
// returns a valid URL for local static builds), and lets the site
// expose `og:url` / canonical without hardcoding a production domain.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#1a1a1a" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* OpenGraph — social / link-preview card. No image yet (pending
        editorial art); the fields below are sufficient for text-first
        previews and won't emit a broken image placeholder when shared. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />

    {/* Twitter — text card. Same reasoning as OG above. */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
  </head>
  <body data-accent={accent ?? null}>
    {/* Skip link — visually hidden until focused. Lets keyboard /
        screen-reader users jump past the header nav to the main
        content area. See docs/design-direction.md §Accessibility. */}
    <a href="#nsb-main" class="nsb-skip-link">Skip to main content</a>

    <header class="nsb-header">
      <div class="nsb-container nsb-header__inner">
        {/* Top-nav wordmark. Reader-facing brand is "The Hard Parts";
            `.nsb-brand` has `text-transform: uppercase` so the three
            words render as THE HARD PARTS. The TLD span stays as the
            yellow secondary cue matching the existing color rhythm
            (yellow dot + yellow .dev) so the nameplate silhouette is
            unchanged. */}
        <a href="/" class="nsb-brand" aria-label="The Hard Parts — home">
          <span class="nsb-brand__dot" aria-hidden="true"></span>
          <span class="nsb-brand__text">The Hard Parts<span class="nsb-brand__tld">.dev</span></span>
        </a>
        <nav class="nsb-nav" aria-label="Primary">
          <ul>
            {CATEGORY_ORDER.map((code) => (
              <li>
                <a
                  href={`/${CATEGORIES[code].route}`}
                  data-accent-link={code.toLowerCase()}
                >
                  <span class="nsb-nav__code">{CATEGORIES[code].shortLabel}</span>
                  <span class="nsb-nav__name">{NAV_NAME_OVERRIDES[code] ?? CATEGORIES[code].name}</span>
                </a>
              </li>
            ))}
            {/* Utility links - sit after the four category buttons so
                the category nav stays the primary axis. Rendered in
                the same outline-pill idiom so they read as siblings,
                not as a separate utility rail. */}
            <li class="nsb-nav__util">
              <a href="/search" aria-label="Search entries">
                <span class="nsb-nav__code" aria-hidden="true">&#x2315;</span>
                <span class="nsb-nav__name">Search</span>
              </a>
            </li>
            <li class="nsb-nav__util">
              <a href="/about">
                <span class="nsb-nav__code" aria-hidden="true">&sect;</span>
                <span class="nsb-nav__name">About</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="nsb-main" id="nsb-main">
      <slot />
    </main>

    <footer class="nsb-footer">
      <div class="nsb-container nsb-footer__inner">
        <p class="nsb-footer__line">
          thehardparts.dev &middot; an engineering reference.
        </p>
        <nav class="nsb-footer__nav" aria-label="Utility">
          <a href="/about">About</a>
          <span class="nsb-footer__sep" aria-hidden="true">&middot;</span>
          <a href="/search">Search</a>
          <span class="nsb-footer__sep" aria-hidden="true">&middot;</span>
          <a href="/sitemap.xml">Sitemap</a>
        </nav>
      </div>
    </footer>

    <style is:global>
      /* Black tabloid nameplate — the top bar of the paper.
         Pure black fill, yellow brand code, white nav pills with hover offset. */
      .nsb-header {
        background: var(--color-frame);
        color: var(--color-surface);
        border-bottom: 3px solid var(--color-frame);
      }
      .nsb-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
        padding-block: var(--space-3);
      }
      .nsb-brand {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
        font-family: var(--font-sans);
        font-weight: 900;
        text-decoration: none;
        letter-spacing: -0.01em;
        font-size: clamp(var(--text-base), 1.5vw, var(--text-lg));
        color: var(--color-surface);
        text-transform: uppercase;
      }
      .nsb-brand__dot {
        width: 0.9rem;
        height: 0.9rem;
        background: var(--color-yellow);
        display: inline-block;
      }
      .nsb-brand__text { color: var(--color-surface); }
      .nsb-brand__tld { color: var(--color-yellow); }
      .nsb-nav ul {
        list-style: none;
        display: flex;
        gap: var(--space-2);
        margin: 0;
        padding: 0;
      }
      /* Shared nav-link chassis — category + utility pills use the
         same outlined-box anatomy now. Color of the text is what
         tells them apart: categories render in the brand yellow
         (they are the primary navigation axis), utility links
         render in white. Both hover to the same solid-yellow fill
         so the hover affordance is consistent. */
      .nsb-nav a {
        font-family: var(--font-sans);
        font-weight: 800;
        font-size: var(--text-xs);
        letter-spacing: var(--tracking-label);
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: baseline;
        gap: var(--space-2);
        padding: 6px 10px;
        border: 2px solid var(--color-surface);
        color: var(--color-yellow);
        transition: background var(--dur-fast) var(--ease),
                    color var(--dur-fast) var(--ease);
      }
      .nsb-nav a:hover {
        background: var(--color-yellow);
        color: var(--color-yellow-ink);
        border-color: var(--color-yellow);
      }
      .nsb-nav a:hover .nsb-nav__code { color: var(--color-yellow-ink); }
      /* The `.nsb-nav__code` span inherits the link's text color by
         default (yellow for categories, white for utility). No
         explicit color here — letting it inherit is what keeps the
         two pill families in sync with their parent link color. */
      .nsb-nav__code {
        font-family: var(--font-sans);
        font-weight: 900;
        font-size: var(--text-xs);
        letter-spacing: var(--tracking-label);
      }
      .nsb-main {
        flex: 1 0 auto;
        padding-block: 0 var(--space-9);
      }
      .nsb-footer {
        border-top: 3px solid var(--color-frame);
        padding-block: var(--space-5);
        background: var(--color-surface);
      }
      .nsb-footer__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--space-3);
      }
      .nsb-footer__line {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--color-ink-soft);
        margin: 0;
      }
      .nsb-footer__nav {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
        font-family: var(--font-sans);
        font-size: var(--text-xs);
        font-weight: 800;
        letter-spacing: var(--tracking-label);
        text-transform: uppercase;
        color: var(--color-ink-soft);
      }
      .nsb-footer__nav a {
        color: var(--color-ink);
        text-decoration-color: var(--color-rule);
      }
      .nsb-footer__nav a:hover { text-decoration-color: var(--accent-current); }
      .nsb-footer__sep { color: var(--color-ink-faint); }

      /* Utility nav items (Search, About) — same outlined-pill
         chassis as categories, but rendered with WHITE text so the
         bar reads as two parallel families:
             [ FAILURE MODES ] [ TECH DECISIONS ] … in yellow
             [ ⌕ SEARCH ] [ § ABOUT ]              in white
         The color swap does all the grouping work, so the earlier
         vertical rule between the two families is gone — it would
         be redundant alongside the color contrast, and crowded at
         narrow widths. A small left margin on the first utility
         item preserves a little breathing room without drawing a
         rule. */
      .nsb-nav li.nsb-nav__util:first-of-type {
        margin-left: var(--space-3);
      }
      .nsb-nav__util a {
        color: var(--color-surface);
      }
      /* Utility glyphs (⌕ / §) sit in the same slot as category
         codes. They inherit the link's white text color by default
         and flip to yellow-ink on hover like the rest of the pill.
         No font-size override here: the glyph shares the parent
         link's `--text-xs` sizing so the utility pill's line-box
         height matches the category pills exactly. An earlier
         `0.95rem` override bumped the glyph a few pixels larger
         and pushed the whole pill ~3px taller than its siblings. */

      /* Category label strategy — inverted on purpose.
         --------------------------------------------------------------
         Earlier iteration showed BOTH the short code ("FM") and the
         full name ("FAILURE MODES") on wide screens. That doubled the
         horizontal footprint of each pill and pushed the whole bar
         into overflow on common laptop widths even after EP was
         shortened.

         The new rule:
           · Wide  (> 1100px): show full name only, hide the code.
             e.g. [ FAILURE MODES ][ TECH DECISIONS ][ RED FLAGS ][ PLAYBOOKS ]
           · Narrow (≤ 1100px): show code only, hide the name.
             e.g. [ FM ][ TD ][ RF ][ EP ]

         Utility links (Search, About) keep both glyph + label at all
         widths — the glyph is ornamental (⌕ / §) and the label is
         the actual affordance. */
      .nsb-nav li:not(.nsb-nav__util) .nsb-nav__code { display: none; }
      @media (max-width: 1100px) {
        .nsb-nav li:not(.nsb-nav__util) .nsb-nav__code { display: inline; }
        .nsb-nav li:not(.nsb-nav__util) .nsb-nav__name { display: none; }
      }

      @media (max-width: 640px) {
        .nsb-header__inner { flex-direction: column; align-items: flex-start; }
        .nsb-nav ul { flex-wrap: wrap; gap: var(--space-2) var(--space-3); }
        /* Drop the extra left-margin on the first utility pill once
           the nav wraps — the row gap from flex-wrap already spaces
           utility pills from the categories above them. */
        .nsb-nav li.nsb-nav__util:first-of-type {
          margin-left: 0;
        }
      }
    </style>
  </body>
</html>
