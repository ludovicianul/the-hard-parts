---
import BaseLayout from "./BaseLayout.astro";
import Tag from "@/components/Tag.astro";
import RelatedEntries from "@/components/RelatedEntries.astro";
import type { FieldNote } from "@/lib/field-notes";
import { formatFieldNoteDate } from "@/lib/field-notes";
import type { CategoryCode } from "@/content/schemas/shared";

export interface Props {
  note: FieldNote;
}

const { note } = Astro.props;
const displayDate = formatFieldNoteDate(note.date);

// Group reference slugs by category code for RelatedEntries blocks.
const CATEGORY_ORDER: CategoryCode[] = ["FM", "TD", "RF", "EP"];
const CATEGORY_LABELS: Record<CategoryCode, string> = {
  FM: "Failure Modes",
  TD: "Tech Decisions",
  RF: "Red Flags",
  EP: "Engineering Playbook",
};
const refsByCode = new Map<CategoryCode, string[]>();
for (const ref of note.references) {
  if (!refsByCode.has(ref.code)) refsByCode.set(ref.code, []);
  refsByCode.get(ref.code)!.push(ref.slug);
}
const refGroups = CATEGORY_ORDER
  .filter((code) => refsByCode.has(code))
  .map((code) => ({ code, slugs: refsByCode.get(code)!, label: CATEGORY_LABELS[code] }));
---
<BaseLayout
  title={note.title}
  description={note.summary}
  ogImage={`/og/essays/${note.slug}.png`}
>
  <article class="nsb-fn-shell">
    {/* Breadcrumbs */}
    <nav class="nsb-fn__crumbs" aria-label="Breadcrumb">
      <div class="nsb-fn__crumbs-inner">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/field-notes">Essays</a></li>
          <li aria-current="page">{note.title}</li>
        </ol>
      </div>
    </nav>

    {/* Masthead */}
    <header class="nsb-fn__masthead nsb-frame nsb-frame--heavy">
      <div class="nsb-fn__masthead-inner">
        <div class="nsb-fn__tagrow">
          <Tag label="Essay" variant="black" size="md" />
          {displayDate && <Tag label={displayDate} variant="yellow" size="md" />}
        </div>
        <h1 class="nsb-display nsb-fn__title">{note.title}</h1>
        {note.summary && <p class="nsb-fn__summary">{note.summary}</p>}
      </div>
    </header>

    {/* Prose body — full width, framed on left/right/bottom */}
    <div class="nsb-fn-shell__body">
      <section class="nsb-fn__body">
        <slot />
      </section>

      {/* Related catalog entries — one RelatedEntries block per category,
          rendered in a two-column grid matching the detail page pattern. */}
      {refGroups.length > 0 && (
        <div class="nsb-fn__related">
          <p class="nsb-fn__related-head">Referenced catalog entries</p>
          <div class="nsb-two-col nsb-two-col--equal">
            {refGroups.map(({ code, slugs, label }) => (
              <RelatedEntries
                title={label}
                refs={slugs}
                expectCategory={code}
                dense
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <style>
    .nsb-fn-shell {
      width: 100%;
      max-width: var(--content-max);
      margin-inline: auto;
      padding-inline: var(--gutter);
      padding-block: var(--space-5) var(--space-8);
    }

    /* Breadcrumbs */
    .nsb-fn__crumbs {
      padding-block: var(--space-4) 0;
    }
    .nsb-fn__crumbs-inner {
      max-width: 100%;
    }
    .nsb-fn__crumbs ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-1) var(--space-2);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-ink-soft);
    }
    .nsb-fn__crumbs ol li + li::before {
      content: "/";
      margin-right: var(--space-2);
      color: var(--color-ink-faint);
    }
    .nsb-fn__crumbs a {
      color: var(--color-ink-soft);
      text-decoration-color: var(--color-rule);
    }
    .nsb-fn__crumbs a:hover { color: var(--color-ink); }

    /* Masthead */
    .nsb-fn__masthead {
      margin-block: var(--space-5) 0;
    }
    .nsb-fn__masthead-inner {
      padding: var(--space-6) var(--space-6);
    }
    .nsb-fn__tagrow {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-bottom: var(--space-4);
    }
    .nsb-fn__title {
      margin: 0 0 var(--space-3) 0;
      font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
      line-height: 1.05;
    }
    .nsb-fn__summary {
      font-family: var(--font-serif);
      font-size: var(--text-lg);
      color: var(--color-ink-dim);
      margin: 0;
      line-height: var(--leading-snug);
    }

    /* Body wrapper */
    .nsb-fn-shell__body {
      padding-block: var(--space-7) var(--space-9);
      border-left: 3px solid var(--color-frame);
      border-right: 3px solid var(--color-frame);
      border-bottom: 3px solid var(--color-frame);
      padding-inline: var(--space-6);
    }

    /* Prose body */
    .nsb-fn__body {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      line-height: var(--leading-relaxed);
      color: var(--color-ink);
    }
    .nsb-fn__body :global(h2) {
      font-family: var(--font-sans);
      font-weight: 900;
      font-size: var(--text-xl);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      margin: var(--space-8) 0 var(--space-3) 0;
      border-bottom: 2px solid var(--color-frame);
      padding-bottom: var(--space-2);
    }
    .nsb-fn__body :global(h3) {
      font-family: var(--font-sans);
      font-weight: 800;
      font-size: var(--text-base);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      margin: var(--space-6) 0 var(--space-2) 0;
    }
    .nsb-fn__body :global(p) {
      margin: 0 0 var(--space-4) 0;
    }
    .nsb-fn__body :global(ul),
    .nsb-fn__body :global(ol) {
      margin: 0 0 var(--space-4) 0;
      padding-left: var(--space-6);
    }
    .nsb-fn__body :global(li) {
      margin-bottom: var(--space-2);
    }
    .nsb-fn__body :global(a) {
      color: var(--color-ink);
      font-weight: 700;
      text-decoration-color: var(--color-rule);
    }
    .nsb-fn__body :global(a:hover) {
      text-decoration-color: var(--color-ink);
    }
    .nsb-fn__body :global(blockquote) {
      border-left: 3px solid var(--color-frame);
      margin: var(--space-5) 0;
      padding: var(--space-2) 0 var(--space-2) var(--space-5);
      font-style: italic;
      color: var(--color-ink-dim);
    }
    .nsb-fn__body :global(code) {
      font-family: var(--font-mono);
      font-size: 0.9em;
      background: var(--color-paper-alt);
      padding: 0.1em 0.35em;
    }
    .nsb-fn__body :global(pre) {
      background: var(--color-paper-alt);
      border: 2px solid var(--color-frame);
      padding: var(--space-4);
      overflow-x: auto;
      margin: 0 0 var(--space-5) 0;
    }
    .nsb-fn__body :global(pre code) {
      background: none;
      padding: 0;
    }
    .nsb-fn__body :global(hr) {
      border: none;
      border-top: 2px solid var(--color-rule);
      margin: var(--space-7) 0;
    }

    /* Related entries section */
    .nsb-fn__related {
      margin-top: var(--space-9);
      padding-top: var(--space-6);
      border-top: 3px solid var(--color-frame);
    }
    .nsb-fn__related-head {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      font-weight: 900;
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-ink-soft);
      margin: 0 0 var(--space-5) 0;
    }
  </style>
</BaseLayout>
