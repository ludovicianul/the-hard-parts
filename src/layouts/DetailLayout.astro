---
import BaseLayout from "./BaseLayout.astro";
import Tag from "@/components/Tag.astro";
import type { CategoryCode } from "@/content/schemas/shared";
import { categoryByCode } from "@/lib/categories";

export interface Props {
  code: CategoryCode;
  title: string;
  summary?: string;
  /** Optional subcategory / family / layer label, rendered as a yellow pill. */
  subcategory?: string;
  /** Optional short description used for <meta name="description">. */
  description?: string;
  /** Optional reference code shown in the black pill on the masthead, e.g. "FM-01". */
  refCode?: string;
}

const { code, title, summary, subcategory, description, refCode } = Astro.props;
const desc = categoryByCode(code);
const accent = code.toLowerCase() as "fm" | "td" | "rf" | "ep";
---
<BaseLayout
  title={title}
  description={description ?? summary}
  accent={accent}
>
  <article class="nsb-detail-shell">
    {/* Breadcrumbs row on paper — small, mono, uppercase. */}
    <nav class="nsb-detail__crumbs" aria-label="Breadcrumb">
      <div class="nsb-detail__crumbs-inner">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href={`/${desc.route}`}>{desc.name}</a></li>
          <li aria-current="page">{title}</li>
        </ol>
      </div>
    </nav>

    {/* Framed bright masthead — the "nameplate" panel. Three stacked rows:
        (1) pill-tag row: reference code + subcategory
        (2) optional slotted meta-bar (severity stamps etc.)
        (3) giant uppercase display title + serif summary
       Everything sits on a white surface inside a heavy black frame. */}
    <header class="nsb-detail__masthead nsb-frame nsb-frame--heavy">
      <div class="nsb-detail__masthead-inner">
        <div class="nsb-detail__tagrow">
          {refCode && <Tag label={refCode} variant="black" size="md" />}
          {subcategory && <Tag label={subcategory} variant="yellow" size="md" />}
          <span class="nsb-detail__tagrow-spacer" />
          <span class="nsb-detail__cat">
            <span class="nsb-detail__cat-code">{desc.shortLabel}</span>
            <span class="nsb-detail__cat-name">{desc.name}</span>
          </span>
        </div>

        {/* Optional meta bar (severity stamps, pills, etc.). */}
        <div class="nsb-detail__metabar">
          <slot name="header-stamp" />
        </div>

        <h1 class="nsb-display nsb-detail__title">{title}</h1>
        {summary && <p class="nsb-detail__summary">{summary}</p>}
      </div>
    </header>

    {/* Body grid: sidebar nav + main content column. */}
    <div class="nsb-detail-shell__grid">
      <aside class="nsb-detail-shell__rail">
        <slot name="nav-rail" />
      </aside>
      <section class="nsb-detail__body">
        <slot />
      </section>
    </div>
  </article>

  <style is:global>
    .nsb-detail-shell {
      width: 100%;
      max-width: 88rem;
      margin-inline: auto;
      padding-inline: var(--gutter);
      padding-block: var(--space-5) var(--space-8);
    }

    /* --- Breadcrumbs row on paper ------------------------------------ */
    .nsb-detail__crumbs {
      margin: 0 0 var(--space-4) 0;
    }
    .nsb-detail__crumbs-inner ol {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin: 0;
      padding: 0;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-label);
    }
    .nsb-detail__crumbs a { color: var(--color-ink); font-weight: 600; }
    .nsb-detail__crumbs a:hover { color: var(--accent-current); }
    .nsb-detail__crumbs li + li::before {
      content: "/";
      color: var(--color-ink-faint);
      margin-right: var(--space-2);
    }

    /* --- Framed bright masthead ------------------------------------- */
    .nsb-detail__masthead {
      margin-bottom: var(--space-7);
    }
    .nsb-detail__masthead-inner {
      padding: clamp(var(--space-5), 3vw, var(--space-7));
      display: grid;
      gap: var(--space-4);
    }
    .nsb-detail__tagrow {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      flex-wrap: wrap;
    }
    .nsb-detail__tagrow-spacer { flex: 1 1 auto; }
    .nsb-detail__cat {
      display: inline-flex;
      align-items: baseline;
      gap: var(--space-2);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-label);
      text-transform: uppercase;
      color: var(--color-label);
    }
    .nsb-detail__cat-code { color: var(--accent-current); font-weight: 700; }
    .nsb-detail__cat-name { color: var(--color-label); }

    .nsb-detail__metabar:empty { display: none; }
    .nsb-detail__metabar {
      display: flex;
      gap: var(--space-2);
      flex-wrap: wrap;
      align-items: center;
      padding: var(--space-3) var(--space-4);
      background: var(--color-paper-alt);
      border: 2px solid var(--color-frame);
      margin: 0;
    }

    .nsb-detail__title {
      margin: var(--space-4) 0 0 0;
    }
    .nsb-detail__summary {
      font-family: var(--font-serif);
      font-size: clamp(var(--text-lg), 1.8vw, var(--text-xl));
      line-height: var(--leading-snug);
      color: var(--color-ink-dim);
      margin: var(--space-4) 0 0 0;
    }

    /* --- Body grid: sidebar + main content -------------------------- */
    .nsb-detail-shell__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    @media (min-width: 1080px) {
      .nsb-detail-shell__grid {
        grid-template-columns: 15rem minmax(0, 1fr);
        gap: var(--space-8);
      }
    }
    .nsb-detail-shell__rail { min-width: 0; }
    .nsb-detail__body { min-width: 0; }
  </style>
</BaseLayout>
